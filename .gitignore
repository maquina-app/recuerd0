# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

.DS_Store

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore Kamal secrets (contains real credentials).
/.kamal/secrets

/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore TODO files (local notes, not committed)
TODO*

# Ignore session transcripts
/transcripts/

# Ignore production/staging deploy configs (contain infrastructure details)
/config/deploy.production.yml
/config/deploy.staging.yml

# Ignore local recuerd0 CLI config
/.recuerd0.yaml

# Ignore AI agent config files
/CLAUDE.md
/.mcp.json

# Ignore spec-driven development specs (local working docs)
/sdd/

# Ignore internal docs (keep docker-deployment.md tracked)
/docs/mvp-plan.md
/docs/research-report.md
/docs/API.md
/docs/brand-guide.md
/docs/brand-voice.md
/docs/hotwire-patterns.md
/docs/technical-guide.md
/docs/ui-patterns.md
