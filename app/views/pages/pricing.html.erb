<% content_for :title, "Pricing for Managed Cloud and Self-Hosted Plans — recuerd0" %>
<% content_for :description, "One product, two ways to run it: the managed cloud at $15/month, or self-host for free. Same features and codebase — your data is yours either way." %>
<% content_for :canonical_url, "https://recuerd0.ai/pricing" %>

<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What's the difference between cloud and self-hosted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both plans include the same features, same limits, and same codebase. Cloud is a managed service where we handle hosting, backups, and updates for you. Self-hosted gives you full control over your own infrastructure and data."
      }
    },
    {
      "@type": "Question",
      "name": "Can I switch between cloud and self-hosted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can migrate between the managed cloud and self-hosting at any time. Export your data via the API from one instance and import it into the other."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a free way to try recuerd0?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The self-hosted version is free forever with no feature limits, so you can run everything locally before moving to the managed cloud — same features, same codebase."
      }
    },
    {
      "@type": "Question",
      "name": "Need more than 10 users?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If your team needs higher limits or custom deployment options, reach out at info@recuerd0.ai and we'll figure it out together."
      }
    }
  ]
}
</script>
<% end %>

<div data-controller="marketing-nav marketing-reveal">

  <%# ========== NAVIGATION ========== %>
  <%= render "pages/marketing_nav" %>

  <%# ========== PRICING HERO ========== %>
  <section class="pricing-hero">
    <div class="m-container">
      <div class="reveal">
        <h1 class="m-section-title">One product. Two ways to run it.</h1>
        <p class="section-desc">
          Same features, same limits, same codebase. Choose the managed cloud for zero maintenance, or self-host for full control.
        </p>
      </div>
    </div>
  </section>

  <%# ========== PRICING CARDS ========== %>
  <section style="padding-top: 0;">
    <div class="pricing-grid">
      <%# Cloud card (featured, primary) %>
      <div class="pricing-card pricing-card-featured reveal reveal-delay-1">
        <div class="pricing-badge">managed</div>
        <h3>Cloud</h3>
        <p class="pricing-desc">We handle the infrastructure so you can focus on your knowledge.</p>
        <div class="pricing-price">
          <span class="pricing-amount">$15</span>
          <span class="pricing-period">/ month</span>
        </div>
        <ul class="pricing-features">
          <li>Up to 10 users per account</li>
          <li>Unlimited workspaces &amp; memories</li>
          <li>Full REST API, CLI &amp; agent workflows</li>
          <li>Full-text search (FTS5)</li>
          <li>Version history</li>
          <li>Managed hosting &amp; backups</li>
          <li>Automatic updates</li>
          <li>Email support</li>
        </ul>
        <div class="pricing-cta">
          <%= link_to "Get Started &rarr;".html_safe, new_registration_path, data: { component: "button", variant: "default" }, class: "btn-primary", style: "width: 100%; justify-content: center;" %>
        </div>
      </div>

      <%# Self-Hosted card (alternative) %>
      <div class="pricing-card reveal reveal-delay-2">
        <h3>Self-Hosted</h3>
        <p class="pricing-desc">Your server, your data. Full control over your infrastructure.</p>
        <div class="pricing-price">
          <span class="pricing-amount">Free</span>
        </div>
        <ul class="pricing-features">
          <li>No user limits</li>
          <li>Unlimited workspaces &amp; memories</li>
          <li>Full REST API, CLI &amp; agent workflows</li>
          <li>Full-text search (FTS5)</li>
          <li>Version history</li>
          <li>Docker image ready to deploy</li>
          <li>Source code access</li>
        </ul>
        <div class="pricing-cta">
          <%= link_to "Get Started &rarr;".html_safe, "https://github.com/maquina-app/recuerd0", target: "_blank", rel: "noopener", data: { component: "button", variant: "ghost" }, class: "btn-ghost", style: "width: 100%; justify-content: center;" %>
        </div>
      </div>
    </div>
  </section>

  <%# ========== NEED MORE? ========== %>
  <section class="pricing-faq">
    <div class="m-container">
      <div class="reveal">
        <h2 class="m-section-title">Need more than 10 users?</h2>
        <p class="section-desc">
          If your team needs higher limits or custom deployment options,
          reach out at <a href="mailto:info@recuerd0.ai">info@recuerd0.ai</a> and we'll figure it out together.
        </p>
      </div>
    </div>
  </section>

  <%# ========== FOOTER ========== %>
  <%= render "pages/marketing_footer" %>

</div>
