<footer class="m-footer">
  <div class="m-container">
    <div class="footer-columns">
      <div class="footer-brand-col">
        <%= image_tag "recuerdo-light.svg", alt: "recuerd0", class: "footer-logo-img" %>
        <span class="footer-tagline">The knowledge base your AI tools deserve</span>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-heading">Product</h4>
        <ul class="footer-col-links">
          <li><%= link_to "API Docs", api_docs_path %></li>
          <li><%= link_to "CLI", cli_path %></li>
          <li><%= link_to "Agents", agents_path %></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-heading">Resources</h4>
        <ul class="footer-col-links">
          <li><%= link_to "Pricing", pricing_path %></li>
          <li><%= link_to "Sign In", new_session_path %></li>
          <li><%= mail_to "info@recuerd0.ai", "Contact" %></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-heading">Legal</h4>
        <ul class="footer-col-links">
          <li><%= link_to "Terms", terms_path %></li>
          <li><%= link_to "Privacy", privacy_path %></li>
          <li><%= link_to "License", license_path %></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-year">&copy; 2026 recuerd0 - Mario Alberto Chávez</span>
      <div class="footer-maquina">
        <span>Designed &amp; built by</span>
        <%= link_to "https://maquina.app", target: "_blank", rel: "noopener" do %>
          <%= image_tag "maquina_logo_horizontal.svg", alt: "Maquina", class: "footer-maquina-img" %>
        <% end %>
      </div>
    </div>
  </div>
</footer>
