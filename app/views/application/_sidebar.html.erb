<%= render "components/sidebar/provider", default_open: recuerd0_sidebar_open?, variant: :inset, cookie_name: "recuerd0_sidebar_state" do %>
  <%= render "components/sidebar", state: recuerd0_sidebar_state, variant: :inset do %>
    <%= render "application/sidebar/header" %>

    <%= render "components/sidebar/content" do %>
      <% if Current.user %>
        <%= render "application/sidebar/main_navigation" %>
      <% end %>
    <% end %>

    <%= render "application/sidebar/footer", user: Current.user %>
  <% end %>

  <%= render "components/sidebar/inset", css_classes: "flex flex-col h-full overflow-hidden" do %>
    <header
      class="
        flex h-(--header-height) shrink-0 items-center gap-2 border-b
        transition-[width,height] ease-linear
        group-has-data-[collapsible=icon]/sidebar-wrapper:h-(--header-height)
      "
    >
      <div class="flex w-full items-center gap-1 px-4 lg:gap-2 lg:px-6">
        <%= render "components/sidebar/trigger", css_classes: "-ml-1" %>

        <%= render "components/separator", orientation: :vertical %>

        <div class="min-w-0 flex-1 overflow-hidden [&_[data-breadcrumb-part=list]]:flex-nowrap">
          <% if content_for?(:breadcrumb) %>
            <%= yield :breadcrumb %>
          <% else %>
            <h1 class="text-base font-medium truncate"><%= content_for(:page_title) || "Dashboard" %></h1>
          <% end %>
        </div>

        <% if Current.user %>
          <div
            class="ml-auto shrink-0"
            data-controller="search-command"
            data-search-command-search-url-value="<%= search_path %>"
            data-action="keydown.meta+k@document->search-command#open keydown.ctrl+k@document->search-command#open"
          >
            <%# Mobile: ghost icon button %>
            <button
              type="button"
              data-action="search-command#open"
              aria-label="<%= t("search.placeholder") %>"
              class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground size-8 md:hidden"
            >
              <%= icon_for(:search, class: "size-4") %>
            </button>

            <%# Desktop: search trigger with shortcut hint %>
            <button
              type="button"
              data-action="search-command#open"
              aria-label="<%= t("search.placeholder") %>"
              class="hidden md:inline-flex items-center gap-2 rounded-md border bg-background px-3 py-1.5 text-sm text-muted-foreground shadow-xs hover:bg-accent hover:text-accent-foreground transition-colors"
            >
              <%= icon_for(:search, class: "size-3.5") %>
              <span class="hidden lg:inline"><%= t("search.placeholder") %></span>
              <kbd
                data-search-command-target="shortcutHint"
                class="pointer-events-none ml-1 inline-flex h-5 items-center rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground"
              ></kbd>
            </button>
          </div>
        <% end %>
      </div>
    </header>

    <div class="flex flex-1 flex-col overflow-hidden">
      <div class="@container/main flex flex-1 flex-col gap-2 overflow-hidden">
        <main class="flex-1 p-4 md:p-6 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  <% end %>
<% end %>
