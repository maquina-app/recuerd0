<%# locals: (sidebar_open: true) %>
<%= render "components/sidebar/provider", default_open: sidebar_open, variant: :inset do %>
  <%= render "components/sidebar", collapsible: :offcanvas, variant: :inset, css_classes: "h-full" do %>
    <%= render "application/sidebar/header" %>

    <%= render "components/sidebar/content" do %>
      <% if Current.user %>
        <%= render "application/sidebar/main_navigation" %>
      <% end %>
    <% end %>

    <%= render "application/sidebar/footer", user: Current.user %>
  <% end %>

  <%= render "components/sidebar/inset", css_classes: "flex flex-col h-full overflow-hidden" do %>
    <header
      class="
        flex h-(--header-height) shrink-0 items-center gap-2 border-b
        transition-[width,height] ease-linear
        group-has-data-[collapsible=icon]/sidebar-wrapper:h-(--header-height)
      "
    >
      <div class="flex w-full items-center gap-1 px-4 lg:gap-2 lg:px-6">
        <%= render "components/sidebar/trigger", css_classes: "-ml-1" %>

        <%= render "components/separator", orientation: :vertical %>

        <% if content_for?(:breadcrumb) %>
          <%= yield :breadcrumb %>
        <% else %>
          <h1 class="text-base font-medium"><%= content_for(:page_title) || "Dashboard" %></h1>
        <% end %>

        <%# Compact inline search — omits data-component="form" and data-form-part="group"
            because the gem's grid layout is not appropriate for a single-field header bar form. %>
        <% if Current.user %>
          <%= form_with url: search_path, method: :get, data: { turbo_action: "advance", controller: "search-form" }, class: "ml-auto" do |f| %>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-2.5">
                <%= icon_for(:search, class: "w-3.5 h-3.5 text-muted-foreground") %>
              </div>
              <%= f.search_field :q, value: (defined?(@query) ? @query : params[:q]), placeholder: t("search.placeholder"), maxlength: 30, data: { component: "input", action: "input->search-form#clear" }, class: "search-input h-9 w-48 lg:w-64 text-sm" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </header>

    <div class="flex flex-1 flex-col overflow-hidden">
      <div class="@container/main flex flex-1 flex-col gap-2 overflow-hidden">
        <main class="flex-1 p-4 md:p-6 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  <% end %>
<% end %>
