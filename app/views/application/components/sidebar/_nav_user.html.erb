<%# locals: (user:) -%>
<%= render "components/sidebar/menu", css_classes: "p-0" do %>
  <%= render "components/sidebar/menu_item" do %>
    <%= render "components/dropdown_menu", css_classes: "w-full", data: { "turbo-temporary": "" } do %>
      <%= render "components/dropdown_menu/trigger", as_child: true, css_classes: "w-full" do %>
        <button
          type="button"
          class="w-[calc(100%-1rem)] mx-2 my-2 px-2 py-2 rounded-md transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground"
          data-dropdown-menu-target="trigger"
          data-action="dropdown-menu#toggle"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <div class="flex items-center gap-2 w-full">
            <%= render "application/components/avatar",
            src: nil,
            alt: user.email_address,
            size: "h-8 w-8",
            grayscale: true,
            css_classes: "avatar rounded-lg" %>
            <div class="grid flex-1 text-left text-sm leading-tight data-[state=collapsed]:hidden">
              <span class="truncate font-medium"><%= user.name.presence || user.email_address.split("@").first %></span>
              <span class="truncate text-xs text-muted-foreground">
                <%= user.email_address %>
              </span>
            </div>
            <%= icon_for :dots_vertical,
            class: "size-4 ml-auto data-[state=collapsed]:hidden" %>
          </div>
        </button>
      <% end %>

      <%= render "components/dropdown_menu/content",
          side: :top,
          align: :start,
          side_offset: 8,
          css_classes: "w-56 rounded-lg",
          style: "min-width: 14rem;" do %>

        <%= render "components/dropdown_menu/label", css_classes: "p-0 font-normal" do %>
          <div class="flex items-center gap-2 px-1 py-1.5 text-left text-sm">
            <%= render "application/components/avatar",
            src: nil,
            alt: user.email_address,
            size: "h-8 w-8",
            css_classes: "avatar rounded-lg" %>
            <div class="grid flex-1 text-left text-sm leading-tight">
              <span class="truncate font-medium"><%= user.name.presence || user.email_address.split("@").first %></span>
              <span class="truncate text-xs text-muted-foreground">
                <%= user.email_address %>
              </span>
            </div>
          </div>
        <% end %>

        <%= render "components/dropdown_menu/separator" %>

        <%= render "components/dropdown_menu/group" do %>
          <%= render "components/dropdown_menu/item", href: account_path do %>
            <%= icon_for :user_circle, class: "size-4" %>
            <%= t("components.sidebar.nav_user.account") %>
          <% end %>

          <%= render "components/dropdown_menu/item", href: profile_path do %>
            <%= icon_for :user, class: "size-4" %>
            <%= t("components.sidebar.nav_user.profile") %>
          <% end %>
        <% end %>

        <%= render "components/dropdown_menu/separator" %>

        <%= render "components/dropdown_menu/item",
            href: session_path,
            data: { turbo_method: :delete } do %>
          <%= icon_for :log_out, class: "size-4" %>
          <%= t("components.sidebar.nav_user.log_out") %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
