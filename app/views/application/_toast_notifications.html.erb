<%# Toast notifications container %>
<%# You can configure the position by setting a data attribute or using a configuration %>
<% toast_position = @toast_position || "top-right" %>

<div
  class="sonner-toaster"
  data-position="<%= toast_position %>"
  aria-live="polite"
  aria-atomic="true"
>
  <% if flash.any? %>
    <% flash.each do |type, message| %>
      <% variant =
        case type.to_s
        when "notice", "success"
          "success"
        when "alert", "error"
          "destructive"
        when "warning"
          "warning"
        when "info"
          "info"
        else
          "default"
        end
      
      icon =
        case variant
        when "success"
          icon_for(
            :check_circle,
            class: "h-5 w-5 text-emerald-600 dark:text-emerald-400",
          )
        when "destructive"
          icon_for(:x_circle, class: "h-5 w-5 text-destructive")
        when "warning"
          icon_for(
            :alert_triangle,
            class: "h-5 w-5 text-yellow-600 dark:text-yellow-400",
          )
        when "info"
          icon_for(:info, class: "h-5 w-5 text-blue-600 dark:text-blue-400")
        else
          nil
        end
      
      # Extract position if provided in flash message
      position = nil
      position = message[:position] || message["position"] if message.is_a?(Hash) %>

      <div
        data-controller="sonner"
        data-sonner-dismiss-after-value="4000"
        data-sonner-remove-after-value="150"
        data-sonner-position-value="<%= position || toast_position %>"
        class="sonner-toast"
      >
        <% description =
          if message.is_a?(Hash)
            message[:description] || message["description"] || message.to_s
          else
            message
          end
        
        title = message.is_a?(Hash) ? (message[:title] || message["title"]) : nil
        action = message.is_a?(Hash) ? (message[:action] || message["action"]) : nil %>

        <%= render "application/components/sonner",
        variant: variant,
        icon: icon,
        title: title,
        description: description,
        action: action,
        class_names: "w-full max-w-[420px]" %>
      </div>
    <% end %>
  <% end %>
</div>
