<%# locals: () %>
<%= render "components/sidebar/group", title: "Workspaces" do %>
  <%= render "components/sidebar/menu" do %>
    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "Workspaces",
          url: workspaces_path,
          icon_name: :folders,
          active: current_page?(workspaces_path) %>
    <% end %>

    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "Archived",
          url: archived_workspaces_path,
          icon_name: :archive,
          active: current_page?(archived_workspaces_path) %>
    <% end %>

    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "Deleted",
          url: deleted_workspaces_path,
          icon_name: :trash_2,
          active: current_page?(deleted_workspaces_path) %>
    <% end %>
  <% end %>
<% end %>

<%= render "components/sidebar/group", title: "Memories" do %>
  <%= render "components/sidebar/menu" do %>
    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "Pinned",
          url: pinned_memories_path,
          icon_name: :pin,
          active: current_page?(pinned_memories_path) %>
    <% end %>
  <% end %>
<% end %>

<%= render "components/sidebar/group", title: "References" do %>
  <%= render "components/sidebar/menu" do %>
    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "API Docs",
          url: "https://recuerd0.ai/api-docs",
          icon_name: :file_text,
          target: "_blank" %>
    <% end %>

    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "CLI",
          url: "https://recuerd0.ai/cli",
          icon_name: :gallery_vertical_end,
          target: "_blank" %>
    <% end %>

    <%= render "components/sidebar/menu_item" do %>
      <%= render "components/sidebar/menu_button",
          title: "Agents",
          url: "https://recuerd0.ai/agents",
          icon_name: :brain,
          target: "_blank" %>
    <% end %>
  <% end %>
<% end %>
