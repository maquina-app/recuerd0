<%# locals: () %>
<% content_for :page_title, t(".title") %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {},
    t(".title"),
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="font-display text-2xl font-medium tracking-tight"><%= t(".title") %></h1>
  </div>

  <% if @query.present? && @query.length < Searchable::MIN_QUERY_LENGTH %>
    <%= render "components/alert", variant: :warning, icon: :alert_triangle, css_classes: "mb-6" do %>
      <strong><%= t(".min_length_title") %></strong>
      <p class="mt-1"><%= t(".min_length_description") %></p>
    <% end %>
  <% elsif @memories.any? %>
    <p class="text-sm text-muted-foreground mb-4">
      <%= t(".results_count", count: @pagy.count, query: @query) %>
    </p>

    <div class="grid gap-4">
      <% @memories.each do |memory| %>
        <div>
          <p class="text-xs text-muted-foreground mb-1">
            <%= icon_for(:folders, class: "w-3 h-3 inline") %>
            <%= link_to memory.workspace.name, workspace_path(memory.workspace), class: "hover:underline" %>
          </p>
          <%= render "memories/memory", memory: memory, workspace: memory.workspace, show_pinned: true %>
        </div>
      <% end %>
    </div>

    <%= pagination_nav(@pagy, :search_path, params: { q: @query }) %>
  <% elsif @query.present? %>
    <%= render "components/empty", variant: :outline do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :search %>
        <%= render "components/empty/title", text: t(".no_results_title") %>
        <%= render "components/empty/description", text: t(".no_results_description", query: @query) %>
      <% end %>
    <% end %>
  <% else %>
    <%= render "components/empty", variant: :outline do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :search %>
        <%= render "components/empty/title", text: t(".empty_title") %>
        <%= render "components/empty/description", text: t(".empty_description") %>
      <% end %>
    <% end %>
  <% end %>
</div>
