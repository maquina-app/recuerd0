<%= render "components/card" do %>
  <%= render "components/card_header", class_names: "text-center" do %>
    <h2 class="text-xl font-semibold">Welcome back</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your email and password to sign in
    </p>
  <% end %>

  <%= render "components/card_content" do %>
    <%= form_with url: session_url do |form| %>
      <div class="grid gap-6">
        <div class="grid gap-6">
          <div class="grid gap-3">
            <%= form.label :email_address, "Email", class: "text-sm font-medium" %>
            <%= form.email_field :email_address,
                             required: true,
                             autofocus: true,
                             autocomplete: "username",
                             placeholder: "m@example.com",
                             value: params[:email_address],
                             class: "w-full" %>
          </div>

          <div class="grid gap-3">
            <div class="flex items-center">
              <%= form.label :password, class: "text-sm font-medium" %>
              <%= link_to "Forgot your password?",
              new_password_path,
              class: "ml-auto text-sm underline-offset-4 hover:underline" %>
            </div>
            <%= form.password_field :password,
                                required: true,
                                autocomplete: "current-password",
                                placeholder: "Enter your password",
                                maxlength: 72,
                                class: "w-full" %>
          </div>

          <%= form.submit "Sign in", class: "btn-default w-full" %>
        </div>

        <div class="text-center text-sm">
          Don't have an account?
          <%= link_to "Sign up", "#", class: "underline underline-offset-4" %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>

<div class="text-center text-xs text-muted-foreground">
  By clicking continue, you agree to our
  <%= link_to "Terms of Service",
  "#",
  class: "underline underline-offset-4 hover:text-primary" %>
  and
  <%= link_to "Privacy Policy",
  "#",
  class: "underline underline-offset-4 hover:text-primary" %>.
</div>
