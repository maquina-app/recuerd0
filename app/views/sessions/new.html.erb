<% content_for :title, "Sign in — recuerd0" %>

<%= render "components/card" do %>
  <%= render "components/card/header", css_classes: "text-center" do %>
    <h2 class="text-xl font-display font-medium">Welcome back</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your email and password to sign in
    </p>
  <% end %>

  <%= render "components/card/content" do %>
    <%= form_with url: session_url, data: { component: "form" } do |form| %>
      <div data-form-part="group">
        <%= form.label :email_address, "Email", data: { component: "label" } %>
        <%= form.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            autocapitalize: "none",
            maxlength: 80,
            placeholder: "m@example.com",
            value: params[:email_address],
            data: { component: "input" } %>
      </div>

      <div data-form-part="group">
        <div class="flex items-center">
          <%= form.label :password, data: { component: "label" } %>
          <%= link_to "Forgot your password?",
              new_password_path,
              class: "ml-auto text-sm underline-offset-4 hover:underline" %>
        </div>
        <%= form.password_field :password,
            required: true,
            autocomplete: "current-password",
            placeholder: "Enter your password",
            maxlength: 72,
            spellcheck: "false",
            data: { component: "input" } %>
      </div>

      <div data-form-part="actions">
        <%= form.submit "Sign in",
            data: { component: "button", variant: "primary" }, class: "w-full" %>
      </div>

      <% if multi_tenant? %>
        <div class="text-center text-sm">
          Don't have an account?
          <%= link_to "Sign up", new_registration_path, class: "underline underline-offset-4" %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<% if multi_tenant? %>
  <div class="text-center text-xs text-muted-foreground">
    By clicking continue, you agree to our
    <%= link_to "Terms of Service",
    terms_path,
    class: "underline underline-offset-4 hover:text-primary" %>
    and
    <%= link_to "Privacy Policy",
    privacy_path,
    class: "underline underline-offset-4 hover:text-primary" %>.
  </div>
<% end %>
