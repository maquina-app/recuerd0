<%# locals: (title:, description: nil, action: nil, icon: nil, class_names: "", **attributes) -%>
<div
  class="<%= cn("flex flex-col items-center justify-center p-8 text-center", class_names) %>"
  <%= tag.attributes(attributes) %>
>
  <% if icon %>
    <div class="mb-4 text-muted-foreground">
      <%= icon %>
    </div>
  <% end %>
  <h3 class="text-lg font-semibold"><%= title %></h3>
  <% if description %>
    <p class="mt-2 text-sm text-muted-foreground max-w-sm"><%= description %></p>
  <% end %>
  <% if action %>
    <div class="mt-4">
      <%= action %>
    </div>
  <% end %>
</div>
