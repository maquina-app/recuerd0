<%# locals: (href: nil, class_names: "", **attributes) -%>

<% if href %>
  <%= link_to href,
      class: cn(
        "transition-colors hover:text-foreground",
        class_names
      ),
      **attributes do %>
    <%= yield %>
  <% end %>
<% else %>
  <%= content_tag :span,
    yield,
    class: cn(
      "transition-colors hover:text-foreground",
      class_names
    ),
    **attributes %>
<% end %>
