<%# locals: (href: nil, active: false, as_child: false, class_names: "", **attributes) -%>
<% is_active = active || (href.present? && sidebar_link_class(href) == "true")
base_classes =
  cn(
    "sidebar-menu-button",
    "group/menu-button",
    "peer/menu-button",
    "rounded-sm",
    class_names,
  ) %>

<% if as_child %>
  <%= content_tag :div, 
      class: base_classes,
      "data-active": is_active,
      **attributes do %>
    <%= yield %>
  <% end %>
<% elsif href.present? %>
  <%= link_to href, 
      class: base_classes,
      "data-active": is_active,
      **attributes do %>
    <span class="flex items-center gap-2 flex-1">
      <%= yield %>
    </span>
    <span class="sr-only">
      <%= is_active ? "(current)" : "" %>
    </span>
  <% end %>
<% else %>
  <%= content_tag :button,
      type: "button",
      class: base_classes,
      "data-active": is_active,
      **attributes do %>
    <%= yield %>
  <% end %>
<% end %>
