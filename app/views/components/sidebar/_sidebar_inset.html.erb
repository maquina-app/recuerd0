<%# locals: (class_names: "", **attributes) -%>

<%= content_tag :main,
  yield,
  class: cn(
    "relative flex w-full flex-1 flex-col",
    # Inset effect styles - always apply on desktop when parent has inset variant
    "md:m-2 md:ml-0 md:rounded-xl md:shadow-sm md:bg-background",
    # When sidebar is collapsed, add left margin
    "[.group\/sidebar-wrapper[data-sidebar-state=collapsed]_&]:md:ml-2",
    class_names
  ),
  "data-slot": :"sidebar-inset",
  **attributes %>
