<%# locals: (open: "true", collapsible: "offcanvas", side: "left", variant: "sidebar", class_names: "", **attributes) -%>

<div
  data-controller="sidebar"
  data-sidebar-collapsible-value="<%= collapsible %>"
  data-sidebar-side-value="<%= side %>"
  data-sidebar-variant-value="<%= variant %>"
  data-sidebar-open-value="<%= open %>"
>
  <%= content_tag :aside,
    yield,
    class: cn(
      "sidebar",
      "flex h-screen flex-col bg-sidebar-background text-sidebar-foreground",
      "transition-all duration-300 ease-in-out",
      "border-r border-sidebar-border",
      # Mobile: fixed overlay
      "fixed inset-y-0 z-50 w-[var(--sidebar-width-mobile)]",
      # Desktop: relative with dynamic width
      "md:relative md:w-[var(--sidebar-width)]",
      "md:data-[state=collapsed]:w-[var(--sidebar-width-icon)]",
      # Mobile: translate based on side
      side == "left" ? "left-0 -translate-x-full data-[state=expanded]:translate-x-0" : "right-0 translate-x-full data-[state=expanded]:-translate-x-0",
      # Desktop: no translate
      "md:translate-x-0 md:data-[state=expanded]:translate-x-0",
      # Variant styles
      variant == "floating" && "md:m-4 md:rounded-lg md:border md:shadow-lg",
      variant == "inset" && "md:border-r-0",
      class_names
    ),
    id: :sidebar,
    "data-sidebar-target": :sidebar,
    "data-state": open ? 'expanded' : 'collapsed',
    **attributes %>

  <!-- Backdrop for mobile -->
  <div
    data-sidebar-target="backdrop"
    data-action="click->sidebar#backdropClick"
    class="
      sidebar-backdrop fixed inset-0 z-40 bg-black/50 md:hidden transition-opacity
      duration-300
    "
    data-state="collapsed"
    aria-hidden="true"
  ></div>
</div>
