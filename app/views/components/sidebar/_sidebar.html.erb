<%# locals: (collapsible: "offcanvas", side: "left", variant: "sidebar", class_names: "", **attributes) -%>
<%# Mobile sidebar %>
<aside
  id="sidebar-mobile"
  data-controller="sidebar"
  data-sidebar-collapsible-value="<%= collapsible %>"
  data-sidebar-side-value="<%= side %>"
  data-sidebar-variant-value="<%= variant %>"
  data-sidebar-target="sidebar"
  data-mobile="true"
  class="<%= cn(
    "md:hidden",
    "flex h-screen flex-col bg-sidebar-background text-sidebar-foreground",
    "fixed inset-y-0 z-50",
    "w-[var(--sidebar-width-mobile)]",
    "transition-transform duration-300 ease-in-out",
    "border-r border-sidebar-border",
    # Side-specific classes
    side == "left" ? "left-0" : "right-0",
    # Initial state - hidden on mobile
    side == "left" ? "-translate-x-full" : "translate-x-full",
    class_names
  ) %>"
  <%= tag.attributes(attributes) %>
>
  <%= yield %>
</aside>

<%# Desktop sidebar %>
<aside
  id="sidebar-desktop"
  data-controller="sidebar"
  data-sidebar-collapsible-value="<%= collapsible %>"
  data-sidebar-side-value="<%= side %>"
  data-sidebar-variant-value="<%= variant %>"
  data-sidebar-target="sidebar"
  data-mobile="false"
  data-state="expanded"
  class="<%= cn(
    "hidden md:flex sidebar-desktop",
    "h-screen flex-col bg-sidebar-background text-sidebar-foreground",
    "relative",
    "transition-[width] duration-300 ease-in-out",
    "border-r border-sidebar-border",
    # Variant styles
    variant == "floating" && "m-4 rounded-lg border shadow-lg",
    variant == "inset" && "border-r-0",
    # Side positioning
    side == "left" ? "left-0" : "right-0",
    class_names
  ) %>"
  <%= tag.attributes(attributes) %>
>
  <%= yield %>
</aside>
<!-- Mobile backdrop -->
<div
  data-sidebar-target="backdrop"
  data-action="click->sidebar#backdropClick"
  class="fixed inset-0 z-40 bg-black/50 hidden md:hidden"
  aria-hidden="true"
></div>
