<%# locals: (default_open: true, variant: "default", class_names: "", **attributes) -%>
<% merged_attributes =
  attributes.merge(
    {
      data: {
        controller: "sidebar-provider",
        sidebar_provider_default_open_value: default_open,
        sidebar_provider_keyboard_shortcut_value:
          attributes.dig(:data, :sidebar_provider_keyboard_shortcut_value) ||
            "b",
        sidebar_state: default_open ? "expanded" : "collapsed",
      }.merge(attributes[:data] || {}),
    },
  ) %>
<div
  data-slot="sidebar-wrapper"
  style="--sidebar-width: calc(var(--spacing) * 64); --sidebar-width-icon: 3rem; --header-height: calc(var(--spacing) * 14)"
  class="<%= cn(
    "group/sidebar-wrapper flex min-h-svh w-full",
    variant == "inset" && "bg-sidebar-background",
    class_names
  ) %>"
  <%= tag.attributes(merged_attributes) %>
>
  <%= yield %>
</div>
