<%# locals: (user:) -%>
<%# Check if we're on mobile via JavaScript (will be set by sidebar controller)
is_mobile = false # Default, will be overridden by JS if needed %>

<%= render "components/sidebar/sidebar_menu", class_names: "p-0" do %>
  <%= render "components/sidebar/sidebar_menu_item" do %>
    <%= render "components/dropdown_menu", class_names: "w-full" do %>
      <%= render "components/dropdown_menu_trigger", as_child: true, class_names: "w-full" do %>
        <%= render "components/sidebar/sidebar_menu_button",
            as_child: true,
            class_names: "w-full px-2 py-2 data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground" do %>
          <div class="flex items-center gap-2 w-full">
            <%= render "components/avatar",
            src: nil, # You can add user.avatar_url if you have avatars
            alt: user.email_address,
            size: "h-8 w-8",
            grayscale: true,
            class_names: "avatar rounded-lg" %>
            <div
              class="
                grid flex-1 text-left text-sm leading-tight data-[state=collapsed]:hidden
              "
            >
              <span class="truncate font-medium"><%= user.email_address.split("@").first %></span>
              <span class="truncate text-xs text-muted-foreground">
                <%= user.email_address %>
              </span>
            </div>
            <%= lucide_icon :dots_vertical,
            size: "w-4 h-4",
            class: "ml-auto data-[state=collapsed]:hidden" %>
          </div>
        <% end %>
      <% end %>

      <%= render "components/dropdown_menu_content",
          side: "top",
          align: "start",
          side_offset: 8,
          class_names: "w-56 rounded-lg",
          style: "min-width: 14rem;" do %>

        <%= render "components/dropdown_menu_label", class_names: "p-0 font-normal" do %>
          <div class="flex items-center gap-2 px-1 py-1.5 text-left text-sm">
            <%= render "components/avatar",
            src: nil,
            alt: user.email_address,
            size: "h-8 w-8",
            class_names: "avatar rounded-lg" %>
            <div class="grid flex-1 text-left text-sm leading-tight">
              <span class="truncate font-medium"><%= user.email_address.split("@").first %></span>
              <span class="truncate text-xs text-muted-foreground">
                <%= user.email_address %>
              </span>
            </div>
          </div>
        <% end %>

        <%= render "components/dropdown_menu_separator" %>

        <%= render "components/dropdown_menu_group" do %>
          <%= render "components/dropdown_menu_item", href: "#" do %>
            <%= lucide_icon :user_circle, size: "w-4 h-4" %>
            Account
          <% end %>

          <%= render "components/dropdown_menu_item", href: "#" do %>
            <%= lucide_icon :credit_card, size: "w-4 h-4" %>
            Billing
          <% end %>

          <%= render "components/dropdown_menu_item", href: "#" do %>
            <%= lucide_icon :bell, size: "w-4 h-4" %>
            Notifications
          <% end %>
        <% end %>

        <%= render "components/dropdown_menu_separator" %>

        <%= render "components/dropdown_menu_item",
            href: session_path,
            data: { turbo_method: :delete } do %>
          <%= lucide_icon :log_out, size: "w-4 h-4" %>
          Log out
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
