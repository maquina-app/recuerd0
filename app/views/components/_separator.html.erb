<%# locals: (orientation: "horizontal", class_names: "", **attributes) -%>
<div
  data-orientation="<%= orientation %>"
  role="none"
  class="<%= cn(
    "bg-border shrink-0",
    orientation == "horizontal" ? "h-px w-full" : "w-px h-full",
    class_names
  ) %>"
  <%= tag.attributes(attributes) %>
/>
