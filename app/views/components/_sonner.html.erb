<%# locals: (variant: "default", title: nil, description: nil, class_names: "", icon: nil, action: nil, **attributes) -%>
<% base_classes =
  "group relative flex w-full items-center justify-between space-x-2 overflow-hidden rounded-md border p-4 pr-6 shadow-lg transition-all"

variant_classes = {
  "default" => "border-border bg-background text-foreground",
  "destructive" =>
    "destructive group border-destructive bg-destructive text-destructive-foreground",
  "success" =>
    "group border-emerald-200 bg-emerald-50 text-emerald-900 dark:border-emerald-800/30 dark:bg-emerald-900/10 dark:text-emerald-200",
  "warning" =>
    "group border-yellow-200 bg-yellow-50 text-yellow-900 dark:border-yellow-800/30 dark:bg-yellow-900/10 dark:text-yellow-200",
  "info" =>
    "group border-blue-200 bg-blue-50 text-blue-900 dark:border-blue-800/30 dark:bg-blue-900/10 dark:text-blue-200",
} %>

<div
  class="<%= cn(base_classes, variant_classes[variant], class_names) %>"
  role="status"
  aria-live="polite"
  <%= tag.attributes(attributes) %>
>
  <div class="flex flex-1 items-start space-x-3">
    <% if icon %>
      <div class="flex-shrink-0">
        <%= icon %>
      </div>
    <% end %>

    <div class="flex-1 space-y-1">
      <% if title %>
        <%= render "components/sonner_title" do %>
          <%= title %>
        <% end %>
      <% end %>

      <% if description %>
        <%= render "components/sonner_description" do %>
          <%= description %>
        <% end %>
      <% elsif block_given? %>
        <%= yield %>
      <% end %>
    </div>
  </div>

  <% if action %>
    <div class="flex-shrink-0">
      <%= action %>
    </div>
  <% end %>

  <button
    type="button"
    class="
      absolute right-1 top-1 rounded-md p-1 text-foreground/50 opacity-0
      transition-opacity hover:text-foreground focus:opacity-100 focus:outline-none
      focus:ring-1 group-hover:opacity-100
    "
    data-action="click->sonner#dismiss"
    aria-label="Close"
  >
    <%= lucide_icon(:x, class: "h-4 w-4") %>
  </button>
</div>
