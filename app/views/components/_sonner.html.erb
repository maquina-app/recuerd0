<%# locals: (variant: "default", title: nil, description: nil, class_names: "", icon: nil, action: nil, **attributes) -%>
<% base_classes =
  "group relative flex w-full items-center justify-between space-x-2 overflow-hidden rounded-md border p-4 pr-6 shadow-lg transition-all"

variant_classes = {
  "default" => "border-border bg-background text-foreground",
  "destructive" => "border-border bg-background text-foreground",
  "success" => "border-border bg-background text-foreground",
  "warning" => "border-border bg-background text-foreground",
  "info" => "border-border bg-background text-foreground",
} %>

<div
  class="<%= cn(base_classes, variant_classes[variant], class_names) %>"
  role="status"
  aria-live="polite"
  <%= tag.attributes(attributes) %>
>
  <div class="flex flex-1 items-start space-x-3">
    <% if icon %>
      <div class="flex-shrink-0">
        <%= icon %>
      </div>
    <% elsif variant != "default" %>
      <div class="flex-shrink-0">
        <% case variant %>
        <% when "destructive" %>
          <%= lucide_icon(:x_circle, class: "h-5 w-5 text-destructive") %>
        <% when "success" %>
          <%= lucide_icon(:check_circle, class: "h-5 w-5 text-success") %>
        <% when "warning" %>
          <%= lucide_icon(:alert_triangle, class: "h-5 w-5 text-warning") %>
        <% when "info" %>
          <%= lucide_icon(:info, class: "h-5 w-5 text-primary") %>
        <% end %>
      </div>
    <% end %>

    <div class="flex-1 space-y-1">
      <% if title %>
        <%= render "components/sonner_title" do %>
          <%= title %>
        <% end %>
      <% end %>

      <% if description %>
        <%= render "components/sonner_description" do %>
          <%= description %>
        <% end %>
      <% elsif block_given? %>
        <div class="text-sm">
          <%= yield %>
        </div>
      <% end %>
    </div>
  </div>

  <% if action %>
    <div class="flex-shrink-0">
      <%= action %>
    </div>
  <% end %>

  <button
    type="button"
    class="
      absolute right-1 top-1 rounded-md p-1 text-muted-foreground opacity-0
      transition-opacity hover:text-foreground focus:opacity-100 focus:outline-none
      focus:ring-1 focus:ring-ring group-hover:opacity-100
    "
    data-action="click->sonner#dismiss"
    aria-label="Close"
  >
    <%= lucide_icon(:x, class: "h-4 w-4") %>
  </button>
</div>
