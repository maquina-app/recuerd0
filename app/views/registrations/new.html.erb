<%= render "components/card" do %>
  <%= render "components/card/header", css_classes: "text-center" do %>
    <h2 class="text-xl font-semibold">Create an account</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your email and choose a password to get started
    </p>
  <% end %>

  <%= render "components/card/content" do %>
    <%= form_with model: @user, url: registration_url do |form| %>
      <div class="grid gap-6">
        <div class="grid gap-6">
          <% if @user.errors.any? %>
            <div class="text-sm text-destructive">
              <% @user.errors.full_messages.each do |message| %>
                <p><%= message %></p>
              <% end %>
            </div>
          <% end %>

          <div class="grid gap-3">
            <%= form.label :email_address, "Email", class: "text-sm font-medium" %>
            <%= form.email_field :email_address,
                             required: true,
                             autofocus: true,
                             autocomplete: "email",
                             placeholder: "m@example.com",
                             class: "w-full" %>
          </div>

          <div class="grid gap-3">
            <%= form.label :password, class: "text-sm font-medium" %>
            <%= form.password_field :password,
                                required: true,
                                autocomplete: "new-password",
                                placeholder: "Choose a password",
                                maxlength: 72,
                                class: "w-full" %>
          </div>

          <div class="grid gap-3">
            <%= form.label :password_confirmation, "Confirm password", class: "text-sm font-medium" %>
            <%= form.password_field :password_confirmation,
                                required: true,
                                autocomplete: "new-password",
                                placeholder: "Confirm your password",
                                maxlength: 72,
                                class: "w-full" %>
          </div>

          <%= form.submit "Create account", class: "btn-default w-full" %>
        </div>

        <div class="text-center text-sm">
          Already have an account?
          <%= link_to "Sign in", new_session_path, class: "underline underline-offset-4" %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>

<div class="text-center text-xs text-muted-foreground">
  By clicking continue, you agree to our
  <%= link_to "Terms of Service",
  "#",
  class: "underline underline-offset-4 hover:text-primary" %>
  and
  <%= link_to "Privacy Policy",
  "#",
  class: "underline underline-offset-4 hover:text-primary" %>.
</div>
