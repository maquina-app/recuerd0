<%# locals: (pinned_workspaces:) %>
<div>
  <h2
    class="
      text-lg font-semibold mb-4 flex items-center gap-2 text-gray-700
      dark:text-gray-300
    "
  >
    <%= lucide_icon :pin, size: "w-4 h-4", class: "rotate-45" %>
    Pinned
  </h2>
  <div id="pinned_workspaces" class="space-y-4">
    <% pinned_workspaces.each do |workspace| %>
      <%= render "workspace", workspace: workspace %>
    <% end %>
  </div>
</div>
