<div class="container mx-auto px-4 py-8 max-w-2xl">
  <%= render "components/card" do %>
    <%= render "components/card_header" do %>
      <h1 class="text-2xl font-bold">Edit Workspace</h1>
      <p class="text-muted-foreground">Update workspace details</p>
    <% end %>

    <%= render "components/card_content" do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
</div>
