<%# locals: () %>
<% content_for :page_title, "Edit Workspace" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Home" => root_path,
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace),
    },
    "Edit",
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <%= render "components/card" do %>
    <%= render "components/card/header" do %>
      <%= render "components/card/title", text: "Edit #{@workspace.name}" %>
      <%= render "components/card/description", text: "Update workspace details" %>
    <% end %>

    <%= render "components/card/content" do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
</div>
