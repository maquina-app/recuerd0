<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="mb-8">
    <%= link_to workspace_path(@workspace), class: "btn-ghost btn-sm mb-4 inline-flex" do %>
      <%= lucide_icon(:arrow_left, size: "w-4 h-4") %>
      Back to
      <%= @workspace.name %>
    <% end %>

    <h1 class="text-3xl font-bold">Edit Workspace</h1>
    <p class="text-muted-foreground mt-2">Update workspace details</p>
  </div>

  <%= render "components/card" do %>
    <%= render "components/card_content", class_names: "pt-6" do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
</div>
