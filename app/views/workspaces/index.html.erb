<% content_for :page_title, "Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs({ "Home" => root_path }, "Workspaces") %>
<% end %>

<div class="mb-8">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold">Workspaces</h1>
      <p class="text-muted-foreground mt-2">Organize your memories into workspaces</p>
    </div>
    <%= link_to new_workspace_path, class: "btn-default" do %>
      <%= lucide_icon(:folder_plus, size: "w-4 h-4") %>
      New Workspace
    <% end %>
  </div>
</div>

<% if @workspaces.any? %>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% @workspaces.each do |workspace| %>
      <%= render "workspace", workspace: workspace %>
    <% end %>
  </div>
<% else %>
  <%= render "components/empty_state",
    title: "No workspaces yet",
    description: "Create your first workspace to start organizing your memories",
    action: link_to(new_workspace_path, class: "btn-default") do %>
    <%= lucide_icon(:folder_plus) %>
    Create Workspace
  <% end %>
<% end %>
