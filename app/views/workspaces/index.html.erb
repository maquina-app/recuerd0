<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold">My Workspaces</h1>
      <p class="text-muted-foreground mt-2">Organize your AI conversations and memories</p>
    </div>
    <%= link_to "New Workspace", new_workspace_path, class: "btn-default" %>
  </div>

  <% if @workspaces.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @workspaces.each do |workspace| %>
        <%= render "workspace", workspace: workspace %>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
    title: "No workspaces yet",
    description: "Create your first workspace to start organizing your AI memories",
    action: link_to("Create Workspace", new_workspace_path, class: "btn-default") %>
  <% end %>
</div>
