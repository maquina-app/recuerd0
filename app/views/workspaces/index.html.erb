<%# locals: () %>
<% content_for :page_title, "Workspaces" %>
<% content_for :breadcrumb do %>
  <%= breadcrumbs({ "Home" => root_path }, "Workspaces") %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8 flex items-center justify-between">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
      Workspaces
    </h1>

    <%= link_to new_workspace_path, data: { component: "button" } do %>
      <%= icon_for(:plus, class: "w-4 h-4") %>
      New Workspace
    <% end %>
  </div>

  <% if @pinned_workspaces.any? %>
    <%= render "workspaces/pinned_section", pinned_workspaces: @pinned_workspaces %>
    <div class="my-8">
      <%= render "components/separator" %>
    </div>
  <% end %>

  <% if @workspaces.any? || @pinned_workspaces.any? %>
    <%= render "workspaces/workspaces_list",
    workspaces: @workspaces,
    pagy: @pagy,
    title: @pinned_workspaces.any? ? "Other Workspaces" : nil %>
  <% else %>
    <%= render "workspaces/empty_state" %>
  <% end %>
</div>
