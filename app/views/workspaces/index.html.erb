<% content_for :breadcrumb do %>
  <nav class="flex" aria-label="Breadcrumb">
    <ol
      class="
        flex items-center space-x-2 text-sm text-gray-600 dark:text-gray-400
      "
    >
      <li>
        <%= link_to "Home", root_path, class: "hover:text-gray-900 dark:hover:text-gray-200" %>
      </li>
      <li class="flex items-center">
        <%= lucide_icon :chevron_right, size: "w-4 h-4", class: "mx-1" %>
        <span class="text-gray-900 dark:text-gray-200">Workspaces</span>
      </li>
    </ol>
  </nav>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8 flex items-center justify-between">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
      Workspaces
    </h1>
    <%= link_to new_workspace_path, class: "btn-default" do %>
      <%= lucide_icon :plus, size: "w-4 h-4" %>
      New Workspace
    <% end %>
  </div>

  <% if @workspaces.any? %>
    <div class="mb-8">
      <h2 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">Active Workspaces</h2>
      <div class="space-y-4">
        <%= render @workspaces %>
      </div>
    </div>
  <% else %>
    <div
      class="
        rounded-lg border-2 border-dashed border-gray-300 p-12 text-center
        dark:border-gray-700
      "
    >
      <%= lucide_icon :folder_open,
      size: "w-12 h-12",
      class: "mx-auto text-gray-400 dark:text-gray-600" %>
      <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">No workspaces</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Get started by creating a new workspace.
      </p>
      <div class="mt-6">
        <%= link_to new_workspace_path, class: "btn-default" do %>
          <%= lucide_icon :plus, size: "w-4 h-4" %>
          New Workspace
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @archived_workspaces.any? %>
    <div class="mb-8">
      <h2 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">
        Archived Workspaces
        <span class="ml-2 text-sm text-gray-500 dark:text-gray-400">
          (<%= @archived_workspaces.count %>)
        </span>
      </h2>
      <div class="space-y-4">
        <%= render partial: "workspace",
        collection: @archived_workspaces,
        locals: {
          show_status: true,
        } %>
      </div>
    </div>
  <% end %>

  <% if @deleted_workspaces.any? %>
    <div class="mb-8">
      <h2 class="mb-4 text-lg font-medium text-gray-900 dark:text-white">
        Deleted Workspaces
        <span class="ml-2 text-sm text-gray-500 dark:text-gray-400">
          (<%= @deleted_workspaces.count %>)
        </span>
      </h2>
      <div class="space-y-4">
        <%= render partial: "workspace",
        collection: @deleted_workspaces,
        locals: {
          show_status: true,
        } %>
      </div>
    </div>
  <% end %>
</div>
