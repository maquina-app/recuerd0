<%# locals: () %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<% content_for :page_title, "Workspaces" %>
<% content_for :breadcrumb do %>
  <%= breadcrumbs({}, "Workspaces") %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="font-display text-2xl font-medium tracking-tight">Workspaces</h1>

    <%= link_to new_workspace_path, data: { component: "button", variant: "default" } do %>
      <%= icon_for(:plus, class: "w-4 h-4") %>
      <%= t("workspaces.index.new_workspace") %>
    <% end %>
  </div>

  <% if @workspaces.any? %>
    <%= render "workspaces/workspaces_list", workspaces: @workspaces, pagy: @pagy %>
  <% else %>
    <%= render "workspaces/empty_state" %>
  <% end %>
</div>
