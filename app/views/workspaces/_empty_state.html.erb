<%# locals: () %>
<%= render "components/empty", variant: :outline do %>
  <%= render "components/empty/header" do %>
    <%= render "components/empty/media", icon: :folder_open %>
    <%= render "components/empty/title", text: "No workspaces" %>
    <%= render "components/empty/description", text: "Get started by creating a new workspace." %>
  <% end %>
  <%= render "components/empty/content" do %>
    <%= link_to new_workspace_path, data: { component: "button" } do %>
      <%= icon_for(:plus, class: "w-4 h-4") %>
      New Workspace
    <% end %>
  <% end %>
<% end %>
