<%# locals: () %>
<%= render "components/empty", variant: :outline do %>
  <%= render "components/empty/header" do %>
    <%= render "components/empty/media", icon: :folder %>
    <%= render "components/empty/title", text: t("workspaces.index.empty_title") %>
    <%= render "components/empty/description", text: t("workspaces.index.empty_description") %>
  <% end %>
  <%= render "components/empty/content" do %>
    <%= link_to new_workspace_path, data: { component: "button", variant: "default" } do %>
      <%= icon_for(:plus, class: "w-4 h-4") %>
      <%= t("workspaces.index.new_workspace") %>
    <% end %>
  <% end %>
<% end %>
