<%# locals: (workspace:, show_status: false) -%>
<div id="<%= dom_id(workspace) %>" class="group flex items-center gap-4 px-4 py-3 rounded-lg transition-colors hover:bg-accent/50 <%= 'opacity-60' if workspace.deleted? %>">
  <%# Name and description %>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <% if workspace.pinned_by?(Current.user) %>
        <%= icon_for(:pin, class: "w-3.5 h-3.5 text-primary rotate-45 flex-shrink-0") %>
      <% end %>
      <h3 class="text-sm font-medium truncate">
        <% if workspace.active? %>
          <%= link_to workspace.name, workspace_path(workspace), class: "hover:underline" %>
        <% elsif workspace.archived? %>
          <%= link_to workspace.name, archived_workspace_path(workspace), class: "hover:underline" %>
        <% elsif workspace.deleted? %>
          <%= link_to workspace.name, deleted_workspace_path(workspace), class: "hover:underline" %>
        <% else %>
          <%= workspace.name %>
        <% end %>
      </h3>
      <% if show_status && workspace.deleted? %>
        <%= render "components/badge", variant: :destructive, css_classes: "text-xs" do %>Deleted<% end %>
      <% elsif show_status && workspace.archived? %>
        <%= render "components/badge", variant: :warning, css_classes: "text-xs" do %>Archived<% end %>
      <% end %>
    </div>
    <% if workspace.description.present? %>
      <p class="text-xs text-muted-foreground truncate mt-0.5"><%= workspace.description %></p>
    <% end %>
  </div>

  <%# Metadata %>
  <div class="hidden sm:flex items-center gap-4 text-xs text-muted-foreground flex-shrink-0">
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:file_text, class: "w-3.5 h-3.5") %>
      <%= workspace.memories_count %>
    </span>
    <span class="inline-flex items-center gap-1 w-20">
      <%= time_ago_in_words(workspace.last_activity) %> ago
    </span>
  </div>

  <%# Actions dropdown %>
  <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= render "components/dropdown_menu" do %>
      <%= render "components/dropdown_menu/trigger", as_child: true do %>
        <button
          type="button"
          data-component="button"
          data-variant="ghost"
          data-size="icon-sm"
          data-dropdown-menu-target="trigger"
          data-action="dropdown-menu#toggle"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label="Workspace actions"
        >
          <%= icon_for(:more_vertical, class: "w-4 h-4") %>
        </button>
      <% end %>

      <%= render "components/dropdown_menu/content",
          align: :end,
          css_classes: "w-48" do %>
        <% if workspace.active? %>
          <%= render "components/dropdown_menu/item",
              href: workspace_path(workspace) do %>
            <%= icon_for(:folder_open, class: "w-4 h-4") %>
            Open
          <% end %>

          <% if workspace.pinned_by?(Current.user) %>
            <%= render "components/dropdown_menu/item",
                href: destroy_pin_path(pinnable_type: workspace.class.name, pinnable_id: workspace.id),
                data: { turbo_method: :delete, turbo_stream: true } do %>
              <%= icon_for(:pin, class: "w-4 h-4") %>
              Unpin
            <% end %>
          <% else %>
            <%= render "components/dropdown_menu/item",
                href: create_pin_path(pinnable_type: workspace.class.name, pinnable_id: workspace.id),
                data: { turbo_method: :post, turbo_stream: true } do %>
              <%= icon_for(:pin, class: "w-4 h-4") %>
              Pin
            <% end %>
          <% end %>

          <%= render "components/dropdown_menu/item",
              href: edit_workspace_path(workspace) do %>
            <%= icon_for(:edit, class: "w-4 h-4") %>
            Edit
          <% end %>

          <%= render "components/dropdown_menu/separator" %>

          <%= render "components/dropdown_menu/item",
              href: archive_workspace_path(workspace),
              data: { turbo_method: :post, turbo_confirm: "Are you sure you want to archive this workspace?" } do %>
            <%= icon_for(:archive, class: "w-4 h-4") %>
            Archive
          <% end %>

          <%= render "components/dropdown_menu/item",
              href: workspace_path(workspace),
              css_classes: "text-destructive focus:text-destructive",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this workspace?" } do %>
            <%= icon_for(:trash_2, class: "w-4 h-4") %>
            Delete
          <% end %>

        <% elsif workspace.archived? %>
          <%= render "components/dropdown_menu/item",
              href: archive_workspace_path(workspace),
              data: { turbo_method: :delete } do %>
            <%= icon_for(:archive_restore, class: "w-4 h-4") %>
            Unarchive
          <% end %>

          <%= render "components/dropdown_menu/separator" %>

          <%= render "components/dropdown_menu/item",
              href: workspace_path(workspace),
              css_classes: "text-destructive focus:text-destructive",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this workspace?" } do %>
            <%= icon_for(:trash_2, class: "w-4 h-4") %>
            Delete
          <% end %>

        <% elsif workspace.deleted? %>
          <%= render "components/dropdown_menu/item",
              href: restore_deleted_workspace_path(workspace),
              data: { turbo_method: :post } do %>
            <%= icon_for(:rotate_ccw, class: "w-4 h-4") %>
            Restore
          <% end %>

          <%= render "components/dropdown_menu/separator" %>

          <%= render "components/dropdown_menu/item",
              href: destroy_deleted_workspace_path(workspace),
              css_classes: "text-destructive focus:text-destructive",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to permanently delete this workspace? This action cannot be undone." } do %>
            <%= icon_for(:trash, class: "w-4 h-4") %>
            Delete permanently
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
