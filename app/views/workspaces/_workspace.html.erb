<%# locals: (workspace:, show_status: false) -%>
<div id="<%= dom_id(workspace) %>" class="group ws-row <%= 'is-deleted' if workspace.deleted? %>">
  <%# Leading folder tile with optional pin marker %>
  <div class="ws-tile">
    <%= icon_for(:folder) %>
    <% if workspace.pinned_by?(Current.user) %>
      <span class="ws-pin-dot">
        <%= icon_for(:pin) %>
        <span class="sr-only"><%= t("workspaces.index.pinned_marker") %></span>
      </span>
    <% end %>
  </div>

  <%# Name, description, stats %>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <h3 class="text-sm font-medium truncate">
        <% if (path = workspace_link_path(workspace)) %>
          <%= link_to workspace.name, path, class: "hover:underline" %>
        <% else %>
          <%= workspace.name %>
        <% end %>
      </h3>
      <%= render "workspaces/workspace_badges", workspace: workspace, show_status: show_status %>
    </div>

    <% if workspace.description.present? %>
      <p class="text-xs text-muted-foreground truncate mt-0.5"><%= workspace.description %></p>
    <% end %>

    <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1">
      <%= render "workspaces/workspace_stats", workspace: workspace %>
    </div>
  </div>

  <%# Actions dropdown — always reachable (visible, no hover gating) %>
  <div class="flex-shrink-0">
    <%= render "components/dropdown_menu", auto_close: true do %>
      <%= render "components/dropdown_menu/trigger", as_child: true do %>
        <button
          type="button"
          data-component="button"
          data-variant="ghost"
          data-size="icon-sm"
          data-dropdown-menu-target="trigger"
          data-action="dropdown-menu#toggle"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label="Workspace actions"
        >
          <%= icon_for(:more_vertical, class: "w-4 h-4") %>
        </button>
      <% end %>

      <%= render "components/dropdown_menu/content",
          align: :end,
          css_classes: "w-48" do %>
        <%= render "workspaces/workspace_actions", workspace: workspace %>
      <% end %>
    <% end %>
  </div>
</div>
