<%# locals: () %>
<% content_for :page_title, t(".page_title") %>

<% content_for :breadcrumb do %>
  <%= responsive_breadcrumbs(
    { "Workspaces" => workspaces_path },
    t("workspaces.deleted.index.breadcrumb"),
  ) %>
<% end %>

<div class="mx-auto max-w-5xl">
  <div class="mb-6 flex items-baseline gap-2.5">
    <h1 class="font-display text-2xl font-medium tracking-tight"><%= t(".heading") %></h1>
    <span class="font-mono text-sm text-muted-foreground"><%= @pagy&.count || @workspaces.size %></span>
  </div>

  <%= render "components/alert", variant: :warning, icon: :trash_2, css_classes: "mb-6" do %>
    <strong><%= t("workspaces.deleted.index.alert_title") %></strong>
    <p class="mt-1"><%= t("workspaces.deleted.index.alert_description") %></p>
  <% end %>

  <% if @workspaces.any? %>
    <div class="mb-5 flex justify-end">
      <%= render "workspaces/view_toggle", view_mode: @view_mode, path_helper: :deleted_workspaces_path %>
    </div>

    <%= render "workspaces/workspaces_list", workspaces: @workspaces, pagy: @pagy, path_helper: :deleted_workspaces_path, view_mode: @view_mode, show_pins: false, show_status: true %>
  <% else %>
    <%= render "workspaces/empty_state_generic", icon: :trash_2, title: t(".empty_title"), description: t(".empty_description") %>
  <% end %>
</div>
