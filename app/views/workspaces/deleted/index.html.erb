<%# locals: () %>
<% content_for :page_title, "Deleted Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "Deleted Workspaces",
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight">Deleted Workspaces</h1>
    <p class="text-muted-foreground mt-1">Manage your deleted workspaces</p>
  </div>

  <%= render "components/alert", variant: :warning, css_classes: "mb-6" do %>
    <div class="flex items-start gap-3">
      <%= icon_for(:trash_2, class: "w-4 h-4 flex-shrink-0 text-amber-600 dark:text-amber-400") %>
      <div>
        <strong>About Deleted Workspaces</strong>
        <p class="mt-1">Deleted workspaces can be restored or permanently removed. Permanently deleting a workspace will also delete all associated memories and cannot be undone.</p>
      </div>
    </div>
  <% end %>

  <% if @workspaces.any? %>
    <div class="divide-y divide-border">
      <% @workspaces.each do |workspace| %>
        <%= render "workspaces/workspace", workspace: workspace %>
      <% end %>
    </div>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="mt-8">
        <%= render "application/components/pagination", pagy: @pagy %>
      </div>
    <% end %>
  <% else %>
    <%= render "components/empty", variant: :dashed do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :trash_2 %>
        <%= render "components/empty/title", text: "No deleted workspaces" %>
        <%= render "components/empty/description", text: "You haven't deleted any workspaces yet." %>
      <% end %>
      <%= render "components/empty/content" do %>
        <%= link_to workspaces_path, data: { component: "button", variant: "secondary" } do %>
          <%= icon_for(:arrow_left, class: "w-4 h-4") %>
          Back to Workspaces
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
