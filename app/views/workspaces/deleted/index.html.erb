<%# locals: () %>
<% content_for :page_title, "Deleted Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "Deleted Workspaces",
  ) %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Deleted Workspaces</h1>
    <p class="text-muted-foreground mt-2">Manage your deleted workspaces</p>
  </div>

  <%= render "components/alert",
  variant: "warning",
  icon: lucide_icon(:trash_2, class: "text-amber-600 dark:text-amber-400"),
  title: "About Deleted Workspaces",
  description:
    "Deleted workspaces can be restored or permanently removed. Permanently deleting a workspace will also delete all associated memories and cannot be undone.",
  class_names: "mb-6" %>

  <% if @workspaces.any? %>
    <div class="space-y-4">
      <% @workspaces.each do |workspace| %>
        <%= render "workspaces/workspace", workspace: workspace %>
      <% end %>
    </div>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="mt-8">
        <%= render "components/pagination", pagy: @pagy %>
      </div>
    <% end %>
  <% else %>
    <div
      class="
        rounded-lg border-2 border-dashed border-gray-300 p-12 text-center
        dark:border-gray-700
      "
    >
      <%= lucide_icon :trash_2,
      size: "w-12 h-12",
      class: "mx-auto text-gray-400 dark:text-gray-600" %>
      <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">No deleted workspaces</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        You haven't deleted any workspaces yet.
      </p>
      <div class="mt-6">
        <%= link_to workspaces_path, class: "btn-secondary" do %>
          <%= lucide_icon(:arrow_left, size: "w-4 h-4") %>
          Back to Workspaces
        <% end %>
      </div>
    </div>
  <% end %>
</div>
