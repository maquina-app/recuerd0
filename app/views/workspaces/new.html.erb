<%# locals: () %>
<% content_for :page_title, "New Workspace" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "New Workspace",
  ) %>
<% end %>

<div class="mx-auto max-w-2xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Create a New Workspace</h1>
    <p class="text-muted-foreground mt-2">Workspaces help you organize your memories</p>
  </div>

  <%= render "components/card" do %>
    <%= render "components/card/content" do %>
      <%= render "form", workspace: @workspace %>
    <% end %>
  <% end %>
</div>
