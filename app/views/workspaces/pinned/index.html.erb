<%# locals: () %>
<% content_for :page_title, "Pinned Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "Pinned Workspaces",
  ) %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Pinned Workspaces</h1>
    <p class="text-muted-foreground mt-2">Your most important workspaces for quick access</p>
  </div>

  <%= render "components/alert", variant: :info, css_classes: "mb-6" do %>
    <div class="flex items-start gap-3">
      <%= icon_for(:pin, class: "w-4 h-4 flex-shrink-0 text-blue-600 dark:text-blue-400 rotate-45") %>
      <div>
        <strong>About Pinned Workspaces</strong>
        <p class="mt-1">Pinned workspaces appear at the top of your workspace list for easy access. You can pin up to 10 workspaces. The most recently pinned workspace appears first.</p>
      </div>
    </div>
  <% end %>

  <% if @workspaces.any? %>
    <div class="space-y-4">
      <% @workspaces.each do |workspace| %>
        <%= render "workspaces/workspace", workspace: workspace %>
      <% end %>
    </div>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="mt-8">
        <%= render "application/components/pagination", pagy: @pagy %>
      </div>
    <% end %>
  <% else %>
    <%= render "components/empty", variant: :dashed do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :pin %>
        <%= render "components/empty/title", text: "No pinned workspaces" %>
        <%= render "components/empty/description", text: "You haven't pinned any workspaces yet. Pin workspaces for quick access." %>
      <% end %>
      <%= render "components/empty/content" do %>
        <%= link_to workspaces_path, data: { component: "button", variant: "secondary" } do %>
          <%= icon_for(:arrow_left, class: "w-4 h-4") %>
          Back to Workspaces
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
