<%# locals: (workspace:) %>
<div class="mb-8 flex justify-between items-center">
  <div>
    <h1 class="text-3xl font-bold"><%= workspace.name %></h1>
    <% if workspace.description.present? %>
      <p class="text-muted-foreground mt-2"><%= workspace.description %></p>
    <% end %>
    <div class="flex flex-col gap-1 mt-4">
      <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
        <%= icon_for(:clock, class: "w-4 h-4 flex-shrink-0") %>
        Created <%= time_ago_in_words(workspace.created_at) %> ago
      </p>
      <% if workspace.archived? && workspace.archived_at.present? %>
        <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
          <%= icon_for(:archive, class: "w-4 h-4 flex-shrink-0") %>
          Archived <%= time_ago_in_words(workspace.archived_at) %> ago
        </p>
      <% end %>
      <% if workspace.deleted? && workspace.deleted_at.present? %>
        <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
          <%= icon_for(:trash_2, class: "w-4 h-4 flex-shrink-0") %>
          Deleted <%= time_ago_in_words(workspace.deleted_at) %> ago
        </p>
        <% days_until_permanent_deletion = 30 - (Date.current - workspace.deleted_at.to_date).to_i %>
        <% if days_until_permanent_deletion > 0 %>
          <p class="inline-flex items-center gap-1 text-sm font-medium text-amber-600 dark:text-amber-400">
            <%= icon_for(:alert_triangle, class: "w-4 h-4 flex-shrink-0") %>
            <%= pluralize(days_until_permanent_deletion, "day") %> until permanent deletion
          </p>
        <% else %>
          <p class="inline-flex items-center gap-1 text-sm font-medium text-red-600 dark:text-red-400">
            <%= icon_for(:alert_triangle, class: "w-4 h-4 flex-shrink-0") %>
            Scheduled for permanent deletion
          </p>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render "workspaces/action_buttons", workspace: workspace %>
</div>
