<%# locals: () %>
<% content_for :page_title, @workspace.name %>

<% content_for :breadcrumb do %>
  <% if @workspace.archived? %>
    <%= breadcrumbs(
      {
        "Home" => root_path,
        "Workspaces" => workspaces_path,
        "Archived Workspaces" => archived_workspaces_path,
      },
      @workspace.name,
    ) %>
  <% elsif @workspace.deleted? %>
    <%= breadcrumbs(
      {
        "Home" => root_path,
        "Workspaces" => workspaces_path,
        "Deleted Workspaces" => deleted_workspaces_path,
      },
      @workspace.name,
    ) %>
  <% else %>
    <%= breadcrumbs(
      { "Home" => root_path, "Workspaces" => workspaces_path },
      @workspace.name,
    ) %>
  <% end %>
<% end %>

<div class="mx-auto max-w-7xl">
  <%= render "workspaces/workspace_header", workspace: @workspace %>

  <% if @workspace.archived? %>
    <%= render "components/alert", variant: :info, css_classes: "mb-6" do %>
      <div class="flex items-start gap-3">
        <%= icon_for(:archive, class: "w-4 h-4 flex-shrink-0 text-blue-600 dark:text-blue-400") %>
        <div>
          <strong>This workspace is archived</strong>
          <p class="mt-1">This workspace is in read-only mode. You can view its contents but cannot make changes. Restore it to continue adding memories.</p>
        </div>
      </div>
    <% end %>
  <% elsif @workspace.deleted? %>
    <% days_until_permanent_deletion = 30 - (Date.current - @workspace.deleted_at.to_date).to_i %>
    <%= render "components/alert", variant: :warning, css_classes: "mb-6" do %>
      <div class="flex items-start gap-3">
        <%= icon_for(:trash_2, class: "w-4 h-4 flex-shrink-0 text-amber-600 dark:text-amber-400") %>
        <div>
          <strong>This workspace is deleted</strong>
          <p class="mt-1">
            This workspace has been deleted and is in read-only mode. You can restore it or permanently delete it along with all its memories.
            <%= days_until_permanent_deletion > 0 ? "This workspace will be permanently deleted in #{pluralize(days_until_permanent_deletion, "day")}." : "This workspace is scheduled for permanent deletion." %>
          </p>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render "workspaces/memories_section",
  workspace: @workspace,
  memories: @memories,
  pagy: @pagy %>
</div>
