<div class="container mx-auto px-4 py-8">
  <div class="mb-8">
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-3xl font-bold"><%= @workspace.name %></h1>
        <% if @workspace.description.present? %>
          <p class="text-muted-foreground mt-2"><%= @workspace.description %></p>
        <% end %>
        <p class="text-sm text-muted-foreground mt-4">
          Created
          <%= time_ago_in_words(@workspace.created_at) %>
          ago
        </p>
      </div>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_workspace_path(@workspace), class: "btn-outline btn-sm" %>
        <%= button_to "Delete",
        workspace_path(@workspace),
        method: :delete,
        data: {
          turbo_confirm:
            "Are you sure you want to delete this workspace and all its memories?",
        },
        class: "btn-destructive btn-sm" %>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h2 class="text-xl font-semibold">Memories</h2>
      <%= link_to "New Memory",
      new_workspace_memory_path(@workspace),
      class: "btn-default btn-sm" %>
    </div>

    <% if @memories.any? %>
      <div class="space-y-4">
        <% @memories.each do |memory| %>
          <%= render "memories/memory", memory: memory, workspace: @workspace %>
        <% end %>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-8">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <%= render "components/empty_state",
      title: "No memories yet",
      description: "Start adding memories to this workspace",
      action:
        link_to(
          "Add First Memory",
          new_workspace_memory_path(@workspace),
          class: "btn-default",
        ) %>
    <% end %>
  </div>
</div>
