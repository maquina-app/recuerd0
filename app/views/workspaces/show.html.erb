<%# locals: () %>
<% content_for :page_title, @workspace.name %>

<% content_for :breadcrumb do %>
  <% if @workspace.archived? %>
    <%= breadcrumbs(
      {
        "Home" => root_path,
        "Workspaces" => workspaces_path,
        "Archived Workspaces" => archived_workspaces_path,
      },
      @workspace.name,
    ) %>
  <% elsif @workspace.deleted? %>
    <%= breadcrumbs(
      {
        "Home" => root_path,
        "Workspaces" => workspaces_path,
        "Deleted Workspaces" => deleted_workspaces_path,
      },
      @workspace.name,
    ) %>
  <% else %>
    <%= breadcrumbs(
      { "Home" => root_path, "Workspaces" => workspaces_path },
      @workspace.name,
    ) %>
  <% end %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold"><%= @workspace.name %></h1>
      <% if @workspace.description.present? %>
        <p class="text-muted-foreground mt-2"><%= @workspace.description %></p>
      <% end %>
      <div class="flex flex-col gap-1 mt-4">
        <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
          <%= lucide_icon(:clock, size: "w-4 h-4", class: "flex-shrink-0") %>
          Created
          <%= time_ago_in_words(@workspace.created_at) %>
          ago
        </p>
        <% if @workspace.archived? && @workspace.archived_at.present? %>
          <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
            <%= lucide_icon(:archive, size: "w-4 h-4", class: "flex-shrink-0") %>
            Archived
            <%= time_ago_in_words(@workspace.archived_at) %>
            ago
          </p>
        <% end %>
        <% if @workspace.deleted? && @workspace.deleted_at.present? %>
          <p class="inline-flex items-center gap-1 text-sm text-muted-foreground">
            <%= lucide_icon(:trash_2, size: "w-4 h-4", class: "flex-shrink-0") %>
            Deleted
            <%= time_ago_in_words(@workspace.deleted_at) %>
            ago
          </p>
          <% days_until_permanent_deletion =
            30 - (Date.current - @workspace.deleted_at.to_date).to_i %>
          <% if days_until_permanent_deletion > 0 %>
            <p
              class="
                inline-flex items-center gap-1 text-sm font-medium text-amber-600
                dark:text-amber-400
              "
            >
              <%= lucide_icon(:alert_triangle, size: "w-4 h-4", class: "flex-shrink-0") %>
              <%= pluralize(days_until_permanent_deletion, "day") %>
              until permanent deletion
            </p>
          <% else %>
            <p
              class="
                inline-flex items-center gap-1 text-sm font-medium text-red-600
                dark:text-red-400
              "
            >
              <%= lucide_icon(:alert_triangle, size: "w-4 h-4", class: "flex-shrink-0") %>
              Scheduled for permanent deletion
            </p>
          <% end %>
        <% end %>
      </div>
    </div>
    <% if @workspace.active? %>
      <div class="flex items-center gap-1">
        <%= link_to edit_workspace_path(@workspace),
            class: "btn-ghost btn-icon-sm",
            title: "Edit workspace" do %>
          <%= lucide_icon :edit, size: "w-4 h-4" %>
        <% end %>

        <%= button_to archive_workspace_path(@workspace),
            method: :post,
            class: "btn-ghost btn-icon-sm cursor-pointer",
            title: "Archive workspace",
            data: { turbo_confirm: "Are you sure you want to archive this workspace?" } do %>
          <%= lucide_icon :archive, size: "w-4 h-4" %>
        <% end %>

        <%= button_to workspace_path(@workspace),
            method: :delete,
            class: "btn-ghost btn-icon-sm cursor-pointer text-destructive hover:text-destructive",
            title: "Delete workspace",
            data: { turbo_confirm: "Are you sure you want to delete this workspace?" } do %>
          <%= lucide_icon :trash_2, size: "w-4 h-4" %>
        <% end %>
      </div>
    <% elsif @workspace.archived? %>
      <div class="flex items-center gap-1">
        <%= button_to archive_workspace_path(@workspace),
            method: :delete,
            class: "btn-ghost btn-icon-sm cursor-pointer",
            title: "Unarchive workspace" do %>
          <%= lucide_icon :archive_restore, size: "w-4 h-4" %>
        <% end %>

        <%= button_to workspace_path(@workspace),
            method: :delete,
            class: "btn-ghost btn-icon-sm cursor-pointer text-destructive hover:text-destructive",
            title: "Delete workspace",
            data: { turbo_confirm: "Are you sure you want to delete this workspace?" } do %>
          <%= lucide_icon :trash_2, size: "w-4 h-4" %>
        <% end %>
      </div>
    <% elsif @workspace.deleted? %>
      <div class="flex items-center gap-1">
        <%= button_to restore_deleted_workspace_path(@workspace),
            method: :post,
            class: "btn-ghost btn-icon-sm cursor-pointer",
            title: "Restore workspace" do %>
          <%= lucide_icon :rotate_ccw, size: "w-4 h-4" %>
        <% end %>

        <%= button_to destroy_deleted_workspace_path(@workspace),
            method: :delete,
            class: "btn-ghost btn-icon-sm cursor-pointer text-destructive hover:text-destructive",
            title: "Permanently delete workspace",
            data: { turbo_confirm: "Are you sure you want to permanently delete this workspace? This action cannot be undone." } do %>
          <%= lucide_icon :trash, size: "w-4 h-4" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @workspace.archived? %>
    <%= render "components/alert",
    variant: "info",
    icon: lucide_icon(:archive, class: "text-blue-600 dark:text-blue-400"),
    title: "This workspace is archived",
    description:
      "This workspace is in read-only mode. You can view its contents but cannot make changes. Restore it to continue adding memories.",
    class_names: "mb-6" %>
  <% elsif @workspace.deleted? %>
    <% days_until_permanent_deletion =
      30 - (Date.current - @workspace.deleted_at.to_date).to_i %>
    <%= render "components/alert",
    variant: "warning",
    icon: lucide_icon(:trash_2, class: "text-amber-600 dark:text-amber-400"),
    title: "This workspace is deleted",
    description:
      "This workspace has been deleted and is in read-only mode. You can restore it or permanently delete it along with all its memories. " +
        (
          if days_until_permanent_deletion > 0
            "This workspace will be permanently deleted in #{pluralize(days_until_permanent_deletion, "day")}."
          else
            "This workspace is scheduled for permanent deletion."
          end
        ),
    class_names: "mb-6" %>
  <% end %>

  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h2 class="text-xl font-semibold">Memories</h2>
      <% if @workspace.active? %>
        <%= link_to new_workspace_memory_path(@workspace), class: "btn-secondary btn-sm" do %>
          <%= lucide_icon(:bookmark_plus, size: "w-4 h-4") %>
          New Memory
        <% end %>
      <% end %>
    </div>

    <% if @memories.any? %>
      <div class="space-y-4">
        <% @memories.each do |memory| %>
          <%= render "memories/memory", memory: memory, workspace: @workspace %>
        <% end %>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-8">
          <%= render "components/pagination", pagy: @pagy %>
        </div>
      <% end %>
    <% else %>
      <div
        class="
          rounded-lg border-2 border-dashed border-gray-300 p-12 text-center
          dark:border-gray-700
        "
      >
        <%= lucide_icon :sticky_note,
        size: "w-12 h-12",
        class: "mx-auto text-gray-400 dark:text-gray-600" %>
        <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">No memories yet</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <% if @workspace.active? %>
            Start adding memories to this workspace.
          <% else %>
            This workspace doesn't have any memories.
          <% end %>
        </p>
        <% if @workspace.active? %>
          <div class="mt-6">
            <%= link_to new_workspace_memory_path(@workspace), class: "btn-secondary" do %>
              <%= lucide_icon(:bookmark_plus, size: "w-4 h-4") %>
              Add First Memory
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
