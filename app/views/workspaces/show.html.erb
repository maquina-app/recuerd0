<%# locals: () %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<% content_for :page_title, @workspace.name %>

<% content_for :breadcrumb do %>
  <%= responsive_breadcrumbs(workspace_breadcrumb_links(@workspace), @workspace.name) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <%# Header %>
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="font-display text-2xl font-medium tracking-tight"><%= @workspace.name %></h1>

        <% if @workspace.archived? %>
          <%= render "components/badge", variant: :warning, css_classes: "text-xs" do %>
            <%= t("workspaces.show.archived_badge") %>
          <% end %>
        <% elsif @workspace.deleted? %>
          <%= render "components/badge", variant: :destructive, css_classes: "text-xs" do %>
            <%= t("workspaces.show.deleted_badge") %>
          <% end %>
        <% end %>

        <% if @workspace.pinned_by?(Current.user) %>
          <%= render "components/badge", variant: :secondary do %>
            <%= icon_for(:pin, class: "size-3") %>
            <%= t("workspaces.show.pinned_badge") %>
          <% end %>
        <% end %>
      </div>

      <% if @workspace.description.present? %>
        <p class="text-muted-foreground mt-1"><%= @workspace.description %></p>
      <% end %>
    </div>

    <div class="flex items-center gap-1 flex-shrink-0 sm:ml-auto">
      <% if @workspace.active? %>
        <%= render "shared/pin_button", pinnable: @workspace %>

        <%= link_to new_workspace_memory_path(@workspace), data: { component: "button", variant: "secondary", size: "sm" } do %>
          <%= icon_for(:bookmark_plus, class: "size-4") %>
          New Memory
        <% end %>
      <% end %>

      <%= render "components/dropdown_menu", auto_close: true do %>
        <%= render "components/dropdown_menu/trigger", as_child: true do %>
          <button
            type="button"
            data-component="button"
            data-variant="ghost"
            data-size="icon-sm"
            data-dropdown-menu-target="trigger"
            data-action="dropdown-menu#toggle"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-label="Workspace actions"
          >
            <%= icon_for(:more_vertical, class: "size-4") %>
          </button>
        <% end %>

        <%= render "components/dropdown_menu/content",
            align: :end,
            css_classes: "w-48" do %>
          <%= render "workspaces/workspace_actions", workspace: @workspace %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# State alerts %>
  <% if @workspace.archived? %>
    <%= render "components/alert", variant: :default, icon: :archive, css_classes: "mb-6" do %>
      <%= render "components/alert/title", text: t("workspaces.show.archived_title") %>
      <%= render "components/alert/description", text: t("workspaces.show.archived_description") %>
    <% end %>
  <% elsif @workspace.deleted? %>
    <% deletion_text = if @workspace.days_until_permanent_deletion > 0
      t("workspaces.show.deleted_description_with_days", days: pluralize(@workspace.days_until_permanent_deletion, "day"))
    else
      t("workspaces.show.deleted_description_scheduled")
    end %>
    <%= render "components/alert", variant: :warning, icon: :trash_2, css_classes: "mb-6" do %>
      <%= render "components/alert/title", text: t("workspaces.show.deleted_title") %>
      <%= render "components/alert/description", text: deletion_text %>
    <% end %>
  <% end %>

  <%# Metadata %>
  <div class="flex items-center gap-4 text-sm text-muted-foreground mb-4">
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:clock, class: "size-4") %>
      Created <%= time_ago_in_words(@workspace.created_at) %> ago
    </span>
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:file_text, class: "size-4") %>
      <%= pluralize(@workspace.memories_count, "memory") %>
    </span>
    <% if @workspace.deleted? && @workspace.days_until_permanent_deletion > 0 %>
      <%= render "components/badge", variant: :destructive, css_classes: "text-xs" do %>
        <%= pluralize(@workspace.days_until_permanent_deletion, "day") %> left
      <% end %>
    <% end %>
  </div>

  <div class="mb-6">
    <%= render "components/separator" %>
  </div>

  <%= render "workspaces/memories_section",
    workspace: @workspace,
    pinned_memories: @pinned_memories,
    regular_memories: @regular_memories,
    pagy: @pagy %>
</div>
