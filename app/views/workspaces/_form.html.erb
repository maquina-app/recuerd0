<%# locals: (workspace:) -%>
<%= form_with(model: workspace, data: { component: "form" }) do |form| %>
  <div data-form-part="group">
    <%= form.label :name, data: { component: "label" } %>
    <%= form.text_field :name,
        autofocus: true,
        placeholder: t("workspaces.form.name_placeholder"),
        required: true,
        maxlength: 100,
        autocomplete: "off",
        data: { component: "input" } %>
    <% if workspace.errors[:name].any? %>
      <p data-form-part="error" class="text-destructive"><%= workspace.errors[:name].first %></p>
    <% end %>
  </div>

  <div data-form-part="group">
    <%= form.label :description, data: { component: "label" } %>
    <%= form.text_area :description,
        rows: 4,
        placeholder: t("workspaces.form.description_placeholder"),
        maxlength: 500,
        autocomplete: "off",
        data: { component: "textarea" } %>
    <% if workspace.errors[:description].any? %>
      <p data-form-part="error" class="text-destructive"><%= workspace.errors[:description].first %></p>
    <% end %>
  </div>

  <div data-form-part="actions">
    <%= form.submit workspace.persisted? ? "Update Workspace" : "Create Workspace",
        data: { component: "button", variant: "primary" } %>

    <%= link_to "Cancel",
        workspace.persisted? ? workspace_path(workspace) : workspaces_path,
        data: { component: "button", variant: "outline" } %>
  </div>
<% end %>
