<%# locals: (workspace:, pinned_memories:, regular_memories:, pagy:) %>

<div class="space-y-6">
  <% if pinned_memories.any? || regular_memories.any? %>
    <%# Pinned memories section %>
    <% if pinned_memories.any? %>
      <div class="space-y-4">
        <h3 class="text-sm font-medium text-muted-foreground flex items-center gap-2">
          <%= icon_for(:pin, class: "w-4 h-4") %> Pinned Memories
        </h3>
        <div class="grid gap-4">
          <% pinned_memories.each do |memory| %>
            <%= render "memories/memory", memory: memory, workspace: workspace, show_pinned: true %>
          <% end %>
        </div>
      </div>
      <% if regular_memories.any? %>
        <%= render "components/separator" %>
      <% end %>
    <% end %>
    <%# Regular memories section %>
    <% if regular_memories.any? %>
      <div class="space-y-4">
        <% if pinned_memories.any? %>
          <h3 class="text-sm font-medium text-muted-foreground">
            All Memories
          </h3>
        <% end %>

        <div class="grid gap-4">
          <% regular_memories.each do |memory| %>
            <%= render "memories/memory", memory: memory, workspace: workspace %>
          <% end %>
        </div>
      </div>
    <% end %>
    <%# Pagination %>
    <div class="mt-6">
      <%= pagination_nav(pagy, :workspace_path, params: { id: workspace.id }) %>
    </div>
  <% else %>
    <%# Empty state %>
    <%= render "components/empty", variant: :outline do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :sticky_note %>
        <%= render "components/empty/title", text: "No memories yet" %>
        <%= render "components/empty/description" do %>
          <% if workspace.active? %>
            Start adding memories to this workspace.
          <% else %>
            This workspace doesn't have any memories.
          <% end %>
        <% end %>
      <% end %>
      <% if workspace.active? %>
        <%= render "components/empty/content" do %>
          <%= link_to new_workspace_memory_path(workspace), data: { component: "button", variant: "secondary" } do %>
            <%= icon_for(:bookmark_plus, class: "w-4 h-4") %>
            Add First Memory
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
