<%# locals: () %>
<% content_for :page_title, "Archived Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "Archived Workspaces",
  ) %>
<% end %>

<div class="mx-auto max-w-7xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Archived Workspaces</h1>
    <p class="text-muted-foreground mt-2">Manage your archived workspaces</p>
  </div>

  <%= render "components/alert",
    variant: "info",
    icon: lucide_icon(:archive, class: "text-blue-600 dark:text-blue-400"),
    title: "About Archived Workspaces",
    description: "Archived workspaces are read-only and cannot be modified. You can restore them at any time to continue working with them.",
    class_names: "mb-6"
  %>

  <% if @workspaces.any? %>
    <div class="space-y-4">
      <% @workspaces.each do |workspace| %>
        <%= render "workspaces/workspace", workspace: workspace %>
      <% end %>
    </div>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="mt-8">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <%= render "components/empty_state",
                     title: "No archived workspaces",
                     description: "You haven't archived any workspaces yet" do %>
      <%= link_to workspaces_path, class: "btn-secondary" do %>
        <%= lucide_icon(:arrow_left) %>
        Back to Workspaces
      <% end %>
    <% end %>
  <% end %>
</div>
