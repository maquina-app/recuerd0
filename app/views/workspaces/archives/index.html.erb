<%# locals: () %>
<% content_for :page_title, t(".page_title") %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Workspaces" => workspaces_path },
    t("workspaces.archives.index.breadcrumb"),
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="font-display text-2xl font-medium tracking-tight"><%= t(".heading") %></h1>
  </div>

  <%= render "components/alert", variant: :default, icon: :archive, css_classes: "mb-6" do %>
    <strong><%= t("workspaces.archives.index.alert_title") %></strong>
    <p class="mt-1"><%= t("workspaces.archives.index.alert_description") %></p>
  <% end %>

  <% if @workspaces.any? %>
    <%= render "workspaces/workspaces_list", workspaces: @workspaces, pagy: @pagy, path_helper: :archived_workspaces_path, show_status: true %>
  <% else %>
    <%= render "workspaces/empty_state_generic", icon: :archive, title: t(".empty_title"), description: t(".empty_description") %>
  <% end %>
</div>
