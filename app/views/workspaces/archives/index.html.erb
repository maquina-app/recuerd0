<%# locals: () %>
<% content_for :page_title, "Archived Workspaces" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    { "Home" => root_path, "Workspaces" => workspaces_path },
    "Archived Workspaces",
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold tracking-tight">Archived Workspaces</h1>
  </div>

  <%= render "components/alert", variant: :success, icon: :archive, css_classes: "mb-6" do %>
    <strong>About Archived Workspaces</strong>
    <p class="mt-1">Archived workspaces are read-only and cannot be modified. You can restore them at any time to continue working with them.</p>
  <% end %>

  <% if @workspaces.any? %>
    <%= render "workspaces/workspaces_list", workspaces: @workspaces, pagy: @pagy, path_helper: :archived_workspaces_path, show_status: true %>
  <% else %>
    <%= render "workspaces/empty_state_generic", icon: :archive, title: "No archived workspaces", description: "You haven't archived any workspaces yet." %>
  <% end %>
</div>
