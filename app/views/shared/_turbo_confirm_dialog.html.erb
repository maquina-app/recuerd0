<dialog
  id="turbo-confirm"
  class="p-0 m-0 backdrop:bg-black/80 max-w-none bg-transparent"
>
  <div class="fixed inset-0 z-50 flex items-center justify-center">
    <div
      class="
        bg-background fixed left-[50%] top-[50%] z-50 grid w-full
        max-w-[calc(100%-2rem)] translate-x-[-50%] translate-y-[-50%] gap-4 rounded-lg
        border p-6 shadow-lg duration-200 sm:max-w-[425px] data-[state=open]:animate-in
        data-[state=closed]:animate-out data-[state=closed]:fade-out-0
        data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95
        data-[state=open]:zoom-in-95
      "
      data-state="open"
    >
      <div class="flex flex-col gap-2 text-center sm:text-left">
        <h2 class="text-lg leading-none font-semibold">
          Confirm Action
        </h2>
        <p id="turbo-confirm-message" class="text-muted-foreground text-sm">
          Are you sure you want to continue?
        </p>
      </div>

      <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
        <button type="button" data-behavior="cancel" class="btn-ghost">
          Cancel
        </button>
        <button type="button" data-behavior="confirm" class="btn-default">
          Confirm
        </button>
      </div>
    </div>
  </div>
</dialog>
