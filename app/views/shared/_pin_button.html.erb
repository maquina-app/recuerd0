<%# locals: (pinnable:) %>
<% if pinnable.pinned_by?(Current.user) %>
  <%= button_to destroy_pin_path(pinnable_type: pinnable.class.name, pinnable_id: pinnable.id),
      method: :delete,
      class: "btn-ghost btn-icon-sm cursor-pointer group",
      title: "Unpin",
      data: { turbo_stream: true } do %>
    <%= lucide_icon :pin,
    size: "w-4 h-4",
    class: "text-primary rotate-45 transition-transform duration-200" %>
  <% end %>
<% else %>
  <%= button_to create_pin_path(pinnable_type: pinnable.class.name, pinnable_id: pinnable.id),
      method: :post,
      class: "btn-ghost btn-icon-sm cursor-pointer group",
      title: "Pin to top",
      data: { turbo_stream: true } do %>
    <%= lucide_icon :pin,
    size: "w-4 h-4",
    class: "transition-all duration-200 group-hover:text-primary" %>
  <% end %>
<% end %>
