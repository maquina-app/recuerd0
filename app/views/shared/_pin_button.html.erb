<%# locals: (pinnable:) %>
<% if pinnable.pinned_by?(Current.user) %>
  <%= button_to destroy_pin_path(pinnable_type: pinnable.class.name, pinnable_id: pinnable.id),
      method: :delete,
      title: "Unpin",
      aria: { label: "Unpin" },
      data: { component: "button", variant: "ghost", size: "icon-sm", turbo_stream: true } do %>
    <%= icon_for :pin, class: "w-4 h-4 text-primary rotate-45" %>
  <% end %>
<% else %>
  <%= button_to create_pin_path(pinnable_type: pinnable.class.name, pinnable_id: pinnable.id),
      method: :post,
      title: "Pin to top",
      aria: { label: "Pin to top" },
      data: { component: "button", variant: "ghost", size: "icon-sm", turbo_stream: true } do %>
    <%= icon_for :pin, class: "w-4 h-4" %>
  <% end %>
<% end %>
