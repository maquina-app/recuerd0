<dialog
  id="search-command-dialog"
  aria-label="<%= t("search.placeholder") %>"
  class="p-0 m-0 backdrop:bg-black/50 max-w-none bg-transparent"
>
  <div class="fixed inset-0 z-50 flex justify-center pt-[20vh]">
    <div class="w-full max-w-lg h-fit rounded-lg border bg-background shadow-lg mx-4 sm:mx-0">
      <form class="flex items-center gap-2 px-3">
        <%= icon_for(:search, class: "size-4 shrink-0 text-muted-foreground") %>
        <input
          type="search"
          name="q"
          id="search-command-input"
          placeholder="<%= t("search.placeholder") %>"
          maxlength="100"
          autocomplete="off"
          class="flex-1 h-12 bg-transparent text-sm text-foreground placeholder:text-muted-foreground border-0 outline-none focus:outline-none focus:ring-0"
        />
      </form>
      <div class="border-t px-3 py-2">
        <p class="text-xs text-muted-foreground"><%= t("search.command.hint") %></p>
      </div>
    </div>
  </div>
</dialog>
