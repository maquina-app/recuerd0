<% content_for :title, "recuerd0 — The knowledge base your AI tools deserve" %>
<% content_for :description, "Organize, version, and serve project context to any LLM — from Claude Code to Cursor to ChatGPT. Human-curated memory, instantly accessible via REST API." %>
<% content_for :canonical_url, "https://recuerd0.ai/" %>

<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "recuerd0",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web, Docker",
  "description": "The knowledge base your AI tools deserve. Organize, version, and serve project context to any LLM.",
  "offers": [
    { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Self-Hosted" },
    { "@type": "Offer", "price": "15", "priceCurrency": "USD", "description": "Cloud", "billingIncrement": "P1M" }
  ]
}
</script>
<% end %>

<div data-controller="marketing-nav marketing-reveal">

  <%# ========== NAVIGATION ========== %>
  <%= render "pages/marketing_nav", show_anchors: true %>

  <%# ========== HERO ========== %>
  <section class="hero">
    <div class="m-container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-badge">source available · self-hosted · cloud</div>
          <h1>The knowledge base your <em>AI tools</em> deserve</h1>
          <p class="hero-sub">
            A small, human-curated knowledge base for your projects — versioned, searchable, and served to any AI tool over a REST API you control.
            Claude Code, Cursor, ChatGPT: one source of truth, no vendor lock-in.
          </p>
          <div class="hero-actions">
            <% if authenticated? %>
              <%= link_to "Go to App \u2192", workspaces_path, data: { component: "button", variant: "default" }, class: "btn-primary" %>
            <% else %>
              <%= link_to "Start free \u2192", new_registration_path, data: { component: "button", variant: "default" }, class: "btn-primary" %>
            <% end %>
            <%= link_to "Self-host \u2192", "https://github.com/maquina-app/recuerd0", target: "_blank", rel: "noopener", data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
          </div>
        </div>

        <div class="hero-visual">
          <div class="memory-layer">
            <div class="layer-body">
              <div class="line" style="width:90%"></div>
              <div class="line"></div>
              <div class="line"></div>
              <div class="line"></div>
            </div>
          </div>
          <div class="memory-layer">
            <div class="layer-header">
              <span class="layer-title">auth-patterns.md</span>
              <span class="layer-version">v2</span>
            </div>
            <div class="layer-tags">
              <span class="layer-tag">auth</span>
              <span class="layer-tag">rails</span>
            </div>
            <div class="layer-body">
              <div class="line"></div>
              <div class="line"></div>
              <div class="line"></div>
            </div>
          </div>
          <div class="memory-layer">
            <div class="layer-header">
              <span class="layer-title">Architecture Guide</span>
              <span class="layer-version">v3</span>
            </div>
            <div class="layer-tags">
              <span class="layer-tag">architecture</span>
              <span class="layer-tag">conventions</span>
              <span class="layer-tag">models</span>
            </div>
            <div class="layer-body" style="font-size:0.75rem; color: var(--m-text-dim); font-family: 'Geist Mono', ui-monospace, monospace; line-height: 1.6;">
              <span style="color: var(--m-text-secondary)"># Models</span><br>
              Use concerns for shared<br>
              behaviors: SoftDeletable,<br>
              Archivable, Pinnable...
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ========== PROBLEM ========== %>
  <section class="problem" id="problem">
    <div class="m-container">
      <div class="reveal">
        <h2 class="m-section-title">Your AI tools forget everything.<br>Every. Single. Session.</h2>
        <p class="section-desc">
          Context engineering has become a core developer skill, yet there are no dedicated tools for it.
          You're using scattered files and copy-paste as makeshift solutions.
        </p>
      </div>

      <div class="problem-grid">
        <div class="problem-card reveal reveal-delay-1">
          <div class="problem-icon">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 8v4l3 3"/>
              <circle cx="12" cy="12" r="10"/>
              <path d="M4 4l4 4M20 4l-4 4" opacity="0.4"/>
            </svg>
          </div>
          <h3>Context Amnesia</h3>
          <p>You re-explain architecture, conventions, and decisions at the start of every session. Five minutes of context setup, every time.</p>
        </div>

        <div class="problem-card reveal reveal-delay-2">
          <div class="problem-icon">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="8" height="8" rx="2"/>
              <rect x="14" y="13" width="8" height="8" rx="2"/>
              <path d="M10 7h4M14 17H10" opacity="0.4"/>
            </svg>
          </div>
          <h3>Context Silos</h3>
          <p>Knowledge prepared for Claude doesn't transfer to Cursor. You maintain duplicate context across every tool in your stack.</p>
        </div>

        <div class="problem-card reveal reveal-delay-3">
          <div class="problem-icon">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18" opacity="0.15"/>
              <path d="M5 19c2-4 5-8 7-9s5 1 7 5" stroke-dasharray="3 3"/>
              <circle cx="12" cy="10" r="2"/>
            </svg>
          </div>
          <h3>Context Drift</h3>
          <p>Your architecture decisions evolve, but stale context leads to AI generating patterns you abandoned months ago. No versioning, no history.</p>
        </div>
      </div>
    </div>
  </section>

  <%# ========== HOW IT WORKS ========== %>
  <section class="how-it-works" id="how">
    <div class="m-container">
      <div class="reveal" style="text-align:center; max-width:560px; margin:0 auto;">
        <h2 class="m-section-title">Curate once, access everywhere</h2>
        <p class="section-desc" style="margin:0 auto;">
          Organize project knowledge into workspaces. Write versioned markdown memories.
          Serve them to any AI tool via API.
        </p>
        <p class="section-desc" style="margin:1rem auto 0; font-family:'Geist Mono',ui-monospace,monospace; font-size:0.85rem; color:var(--m-text-dim);">
          MEMORY.md for the cheat sheet. recuerd0 for the deep knowledge. Query exactly the context you need.
        </p>
      </div>

      <div class="flow-diagram reveal">
        <div class="flow-step">
          <div class="flow-icon">
            <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--m-primary)" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="3"/>
              <path d="M3 9h18M9 3v18" opacity="0.4"/>
            </svg>
          </div>
          <h3>Organize</h3>
          <p>Group memories into workspaces — one per project, domain, or team context.</p>
        </div>

        <div class="flow-arrow">
          <svg aria-hidden="true" width="32" height="16" viewBox="0 0 32 16" fill="none">
            <path d="M0 8h28M22 2l6 6-6 6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>

        <div class="flow-step">
          <div class="flow-icon">
            <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--m-primary)" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="9" y1="13" x2="15" y2="13" opacity="0.4"/>
              <line x1="9" y1="17" x2="13" y2="17" opacity="0.4"/>
            </svg>
          </div>
          <h3>Write</h3>
          <p>Create markdown memories with tags, versioning, and full-text search.</p>
        </div>

        <div class="flow-arrow">
          <svg aria-hidden="true" width="32" height="16" viewBox="0 0 32 16" fill="none">
            <path d="M0 8h28M22 2l6 6-6 6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>

        <div class="flow-step">
          <div class="flow-icon">
            <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--m-primary)" stroke-width="1.5">
              <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
              <line x1="4" y1="22" x2="4" y2="15" opacity="0.4"/>
            </svg>
          </div>
          <h3>Serve</h3>
          <p>REST API with Bearer auth. Point any AI tool at your knowledge, instantly.</p>
        </div>
      </div>
    </div>
  </section>

  <%# ========== API SHOWCASE ========== %>
  <section class="code-section" id="api">
    <div class="m-container">
      <div class="reveal">
        <h2 class="m-section-title">Built for developer workflows</h2>
        <p class="section-desc">
          Full REST API with token authentication. CLI for terminal access.
          Agent workflows for persistent AI memory.
        </p>
        <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <%= link_to "Full API Reference →", api_docs_path, data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
          <%= link_to "CLI Reference →", cli_path, data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
          <%= link_to "Agent Workflows →", agents_path, data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
        </div>
      </div>

      <div class="code-tabs reveal reveal-delay-1" data-controller="code-tabs">
        <div class="code-tab-bar" role="tablist" aria-label="Code examples">
          <button class="code-tab" role="tab" id="code-tab-0" aria-controls="code-panel-0" tabindex="0" data-code-tabs-target="tab" data-action="code-tabs#select keydown->code-tabs#navigate" data-index="0" data-state="active" aria-selected="true">rest api</button>
          <button class="code-tab" role="tab" id="code-tab-1" aria-controls="code-panel-1" tabindex="-1" data-code-tabs-target="tab" data-action="code-tabs#select keydown->code-tabs#navigate" data-index="1" data-state="inactive" aria-selected="false">cli</button>
          <button class="code-tab" role="tab" id="code-tab-2" aria-controls="code-panel-2" tabindex="-1" data-code-tabs-target="tab" data-action="code-tabs#select keydown->code-tabs#navigate" data-index="2" data-state="inactive" aria-selected="false">agents</button>
        </div>

        <div class="code-block" role="tabpanel" id="code-panel-0" aria-labelledby="code-tab-0" tabindex="0" data-code-tabs-target="panel">
          <div class="code-header">
            <div class="code-dots"><span></span><span></span><span></span></div>
            <span class="code-lang">rest api</span>
          </div>
          <div class="code-body">
<code><span class="comment"># List workspace memories</span>
<span class="keyword">GET</span> /workspaces/<span class="num">1</span>/memories.json

<span class="comment"># Search across all memories</span>
<span class="keyword">GET</span> /search.json?q=<span class="string">authentication</span>

<span class="comment"># Create a new memory</span>
<span class="keyword">POST</span> /workspaces/<span class="num">1</span>/memories.json
{
  <span class="string">"memory"</span>: {
    <span class="string">"title"</span>: <span class="string">"Auth Conventions"</span>,
    <span class="string">"content"</span>: <span class="string">"# Authentication\n..."</span>,
    <span class="string">"tags"</span>: [<span class="string">"auth"</span>, <span class="string">"rails"</span>]
  }
}

<span class="comment"># Version a memory</span>
<span class="keyword">POST</span> /workspaces/<span class="num">1</span>/memories/<span class="num">5</span>/versions.json</code>
          </div>
        </div>

        <div class="code-block hidden" role="tabpanel" id="code-panel-1" aria-labelledby="code-tab-1" tabindex="0" data-code-tabs-target="panel">
          <div class="code-header">
            <div class="code-dots"><span></span><span></span><span></span></div>
            <span class="code-lang">cli tool</span>
          </div>
          <div class="code-body">
<code><span class="comment"># Setup your account</span>
$ <span class="fn">recuerd0</span> <span class="flag">account add</span> personal <span class="flag">--token</span> <span class="string">YOUR_TOKEN</span>

<span class="comment"># Search your knowledge</span>
$ <span class="fn">recuerd0</span> <span class="flag">search</span> <span class="string">"turbo streams"</span>

<span class="comment"># Create a memory</span>
$ <span class="fn">recuerd0</span> <span class="flag">memory create</span> <span class="flag">--workspace</span> <span class="num">1</span> <span class="flag">--title</span> <span class="string">"Go patterns"</span> <span class="flag">--content</span> <span class="string">"..."</span>

<span class="comment"># Read a memory</span>
$ <span class="fn">recuerd0</span> <span class="flag">memory show</span> <span class="flag">--workspace</span> <span class="num">1</span> <span class="num">42</span>

<span class="comment"># Pipe content from stdin</span>
$ <span class="fn">cat</span> notes.md | <span class="fn">recuerd0</span> <span class="flag">memory create</span> <span class="flag">--workspace</span> <span class="num">1</span> <span class="flag">--title</span> <span class="string">"Notes"</span> <span class="flag">--content</span> -</code>
          </div>
        </div>

        <div class="code-block hidden" role="tabpanel" id="code-panel-2" aria-labelledby="code-tab-2" tabindex="0" data-code-tabs-target="panel">
          <div class="code-header">
            <div class="code-dots"><span></span><span></span><span></span></div>
            <span class="code-lang">agent config</span>
          </div>
          <div class="code-body">
<code><span class="comment"># CLAUDE.md agent config</span>
<span class="comment">## Memory Server</span>
<span class="fn">recuerd0 API</span>: <span class="string">https://recuerd0.ai/api</span>
<span class="fn">token</span>: <span class="var">$RECUERDO_TOKEN</span>

<span class="comment">## Pre-session</span>
Search workspace <span class="string">"rails-app"</span> for
relevant context before starting.

<span class="comment">## Post-session</span>
Save key decisions and patterns
as new versioned memories.</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ========== FEATURES ========== %>
  <section class="features" id="features">
    <div class="m-container">
      <div class="reveal">
        <h2 class="m-section-title">Everything you need, nothing you don't</h2>
        <p class="section-desc">
          Built with Rails 8, SQLite, and a philosophy of simplicity.
          No external services, no data leaving your network.
        </p>
      </div>

      <div class="features-grid">
        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></svg></div>
          <div>
            <h3>Human-Curated</h3>
            <p>Deliberate, human-in-the-loop knowledge — not automatic capture that accumulates noise. Every memory earns its place: reviewed, versioned, and yours.</p>
            <div class="feature-meta">
              <span class="feature-chip">human-curated</span>
              <span class="feature-chip">versioned</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg></div>
          <div>
            <h3>Version History</h3>
            <p>Branch from any version with a flat versioning model. Track how your project knowledge evolves — like Git for context.</p>
            <div class="feature-meta">
              <span class="feature-chip">branching</span>
              <span class="feature-chip">consolidation</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></div>
          <div>
            <h3>Full-Text Search</h3>
            <p>Keyword search powered by SQLite FTS5 with the trigram tokenizer. Search every workspace in milliseconds, from 3-character queries up. Focused, curated workspaces keep the context you need easy to find.</p>
            <div class="feature-meta">
              <span class="feature-chip">fts5</span>
              <span class="feature-chip">trigram</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17H7A5 5 0 0 1 7 7h2"/><path d="M15 7h2a5 5 0 1 1 0 10h-2"/><line x1="8" y1="12" x2="16" y2="12"/></svg></div>
          <div>
            <h3>Tool Agnostic</h3>
            <p>A REST API with Bearer auth works with any tool — Cursor, ChatGPT, your own scripts. For Claude Code there's a native agent: slash commands plus auto-save hooks that capture session knowledge without leaving the harness. No vendor lock-in, ever.</p>
            <div class="feature-meta">
              <span class="feature-chip">rest-api</span>
              <span class="feature-chip">cli</span>
              <span class="feature-chip">ai-agent</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg></div>
          <div>
            <h3>Deploy Your Way</h3>
            <p>Self-host with Docker on your own infrastructure, or use the managed cloud. Same features, same limits — you choose where your data lives.</p>
            <div class="feature-meta">
              <span class="feature-chip">docker</span>
              <span class="feature-chip">cloud</span>
              <span class="feature-chip">sqlite</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <div>
            <h3>Team Sharing</h3>
            <p>Account-based multi-tenancy with admin and member roles. Invite up to 10 users with signed tokens. Share canonical project knowledge.</p>
            <div class="feature-meta">
              <span class="feature-chip">roles</span>
              <span class="feature-chip">invitations</span>
            </div>
          </div>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg></div>
          <div>
            <h3>Workspace Organization</h3>
            <p>Pin, archive, soft-delete, and tag. Workspaces are tuned for a curated set of high-value memories — think dozens, curation over accumulation — so the context you serve stays sharp, not noisy. Deep, large workspaces work too; keeping recall sharp as they grow is what semantic search (on the roadmap) is for.</p>
            <div class="feature-meta">
              <span class="feature-chip">pins</span>
              <span class="feature-chip">tags</span>
              <span class="feature-chip">archive</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ========== CTA ========== %>
  <section class="cta-section" id="start">
    <div class="m-container">
      <div class="reveal">
        <h2 class="m-section-title">Stop re-explaining your project.<br>Start <em style="color:var(--m-primary);font-style:normal;font-family:'Jura',system-ui,sans-serif;font-weight:500;">preserving</em>.</h2>
        <p class="section-desc">
          One command. Your server, your data, your context &mdash; accessible from any AI tool.
        </p>
      </div>

      <div class="cta-actions reveal reveal-delay-1" style="flex-direction: column; align-items: center; gap: 1.5rem;">
        <%= link_to "Self-hosted \u2192", "https://github.com/maquina-app/recuerd0", target: "_blank", rel: "noopener", data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
        <span style="font-family: 'Geist Mono', ui-monospace, monospace; font-size: 0.72rem; letter-spacing: 1px; text-transform: uppercase; color: var(--m-text-dim);">or</span>
        <div style="display: flex; gap: 1rem; align-items: center;">
          <% if authenticated? %>
            <%= link_to "Go to App \u2192", workspaces_path, data: { component: "button", variant: "default" }, class: "btn-primary" %>
          <% else %>
            <%= link_to "Start with Cloud \u2192", new_registration_path, data: { component: "button", variant: "default" }, class: "btn-primary" %>
          <% end %>
          <%= link_to "See pricing", pricing_path, data: { component: "button", variant: "ghost" }, class: "btn-ghost" %>
        </div>
      </div>
    </div>
  </section>

  <%# ========== FOOTER ========== %>
  <%= render "pages/marketing_footer" %>

</div>
