<%# locals: (workspace:, memory:) %>

<%= form_with model: [workspace, memory], local: true, class: "flex flex-col h-full space-y-4", data: { component: "form" } do |form| %>
  <%# Title field %>
  <div data-form-part="group">
    <%= form.label :title, data: { component: "label" } %>
    <%= form.text_field :title,
        placeholder: "Untitled Memory",
        data: { component: "input" } %>
    <% if memory.errors[:title].any? %>
      <p data-form-part="error"><%= memory.errors[:title].first %></p>
    <% end %>
  </div>

  <%# Content field - takes remaining space %>
  <div class="flex-1 flex flex-col min-h-0" data-form-part="group">
    <%= form.label :content, "Content (Markdown)", data: { component: "label" } %>
    <%= text_area_tag "memory[content]",
        memory.content&.body,
        class: "flex-1 resize-none overflow-y-auto font-mono text-sm",
        placeholder: "Enter your memory content using Markdown...",
        data: { component: "textarea" } %>
    <p class="text-xs text-muted-foreground mt-1.5">
      Supports Markdown formatting
    </p>
  </div>

  <%# Collapsible metadata section with animation %>
  <details
    class="group border rounded-md border-border"
    data-controller="details"
    data-action="toggle->details#handleToggle"
  >
    <summary
      class="
        flex items-center justify-between px-4 py-3 cursor-pointer
        hover:bg-accent/50 transition-colors list-none
        [&::-webkit-details-marker]:hidden
      "
    >
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= icon_for(:info, class: "w-4 h-4 text-muted-foreground") %> Additional Information
      </span>
      <span
        class="
          text-muted-foreground transition-transform duration-200
          group-open:rotate-180
        "
      >
        <%= icon_for(:chevron_down, class: "w-4 h-4") %>
      </span>
    </summary>

    <div
      class="
        grid grid-rows-[0fr] group-open:grid-rows-[1fr]
        transition-[grid-template-rows] duration-200 ease-out
      "
    >
      <div class="overflow-hidden">
        <div class="px-4 pb-4 pt-2 space-y-4 border-t border-border bg-muted/20">
          <%# Source field %>
          <div data-form-part="group">
            <%= form.label :source, data: { component: "label" } %>
            <%= form.text_field :source,
                placeholder: "e.g., Claude, Book Title, URL...",
                data: { component: "input" } %>
            <% if memory.errors[:source].any? %>
              <p data-form-part="error"><%= memory.errors[:source].first %></p>
            <% end %>
          </div>

          <%# Tags field %>
          <div data-form-part="group">
            <%= form.label :tags, data: { component: "label" } %>
            <%= render "application/components/tag_input", form: form, field: :tags, value: memory.tags %>
            <p class="text-xs text-muted-foreground mt-1.5">
              Press Enter or comma to add tags
            </p>
          </div>
        </div>
      </div>
    </div>
  </details>

  <%# Submit buttons %>
  <div data-form-part="actions">
    <%= form.submit data: { component: "button" } %>
    <%= link_to "Cancel", workspace_path(workspace), data: { component: "button", variant: "outline" } %>
  </div>
<% end %>
