<% content_for :page_title, action_name == "new" ? "New Memory" : "Edit Memory" %>

<%# locals: (workspace:, memory:) %>

<%= form_with model: [workspace, memory], local: true, class: "flex flex-col h-full space-y-4" do |form| %>
  <%# Error messages %>
  <% if memory.errors.any? %>
    <%= render "components/alert", variant: "destructive" do %>
      <%= render "components/alert_title" do %>
        <%= pluralize(memory.errors.count, "error") %>
        prevented this memory from being saved:
      <% end %>
      <%= render "components/alert_description" do %>
        <ul class="list-disc list-inside space-y-1">
          <% memory.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  <% end %>

  <%# Title field %>
  <div>
    <%= form.label :title, class: "block mb-2" %>
    <%= form.text_field :title, 
        placeholder: "Untitled Memory" %>
    <% if memory.errors[:title].any? %>
      <p class="error-message mt-1"><%= memory.errors[:title].first %></p>
    <% end %>
  </div>

  <%# Content field - takes remaining space %>
  <div class="flex-1 flex flex-col min-h-0">
    <%= form.label :content, "Content (Markdown)", class: "block mb-2" %>
    <%= text_area_tag "memory[content]", 
        memory.content&.body, 
        class: "flex-1 resize-none overflow-y-auto font-mono text-sm",
        placeholder: "Enter your memory content using Markdown..." %>
    <p class="text-xs text-muted-foreground mt-1.5">
      Supports Markdown formatting
    </p>
  </div>

  <%# Collapsible metadata section with animation %>
  <details
    class="group border rounded-md border-border"
    data-controller="details"
    data-action="toggle->details#handleToggle"
  >
    <summary
      class="
        flex items-center justify-between px-4 py-3 cursor-pointer
        hover:bg-accent/50 transition-colors list-none
        [&::-webkit-details-marker]:hidden
      "
    >
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon(:info, size: "w-4 h-4", class: "text-muted-foreground") %> Additional Information
      </span>
      <span
        class="
          text-muted-foreground transition-transform duration-200
          group-open:rotate-180
        "
      >
        <%= lucide_icon(:chevron_down, size: "w-4 h-4") %>
      </span>
    </summary>

    <div
      class="
        grid grid-rows-[0fr] group-open:grid-rows-[1fr]
        transition-[grid-template-rows] duration-200 ease-out
      "
    >
      <div class="overflow-hidden">
        <div class="px-4 pb-4 pt-2 space-y-4 border-t border-border bg-muted/20">
          <%# Source field %>
          <div>
            <%= form.label :source, class: "block mb-2" %>
            <%= form.text_field :source, 
                placeholder: "e.g., Claude, Book Title, URL..." %>
            <% if memory.errors[:source].any? %>
              <p class="error-message mt-1">
                <%= memory.errors[:source].first %>
              </p>
            <% end %>
          </div>

          <%# Tags field %>
          <div>
            <%= form.label :tags, class: "block mb-2" %>
            <%= render "components/tag_input", form: form, field: :tags, value: memory.tags %>
            <p class="text-xs text-muted-foreground mt-1.5">
              Press Enter or comma to add tags
            </p>
          </div>
        </div>
      </div>
    </div>
  </details>

  <%# Submit buttons %>
  <div class="flex items-center gap-4 pt-2">
    <%= form.submit class: "btn-default" %>
    <%= link_to "Cancel", workspace_path(workspace), class: "btn-outline" %>
  </div>
<% end %>
