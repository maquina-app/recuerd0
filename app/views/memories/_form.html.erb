<%# locals: (workspace:, memory:) %>

<div class="h-full flex flex-col">
  <%# Custom form layout — intentionally omits data-component="form" to avoid the
      gem's grid/gap styling. This editor layout uses its own flex structure to
      maximize the writing area. Individual inputs still use data-component
      attributes for consistent styling. The House MD editor is a form-associated
      Web Component and syncs its value on submit, so standard Turbo Drive works. %>
  <%= form_with model: [workspace, memory], class: "flex flex-col h-full gap-3" do |form| %>
    <%# Toolbar: title + actions %>
    <div class="shrink-0 flex items-center gap-2">
      <div class="flex-1 min-w-0" data-form-part="group">
        <%= form.text_field :title,
            placeholder: t("memories.form.title_placeholder"),
            maxlength: 255,
            autocomplete: "off",
            data: { component: "input" } %>
        <% if memory.errors[:title].any? %>
          <p data-form-part="error" class="text-destructive"><%= memory.errors[:title].first %></p>
        <% end %>
      </div>
      <div class="hidden sm:flex shrink-0 items-center gap-2">
        <%= link_to t("memories.form.cancel"),
            memory.persisted? ? workspace_memory_path(workspace, memory) : workspace_path(workspace),
            data: { component: "button", variant: "outline", size: "sm" } %>
        <%= form.submit memory.persisted? ? t("memories.form.save") : t("memories.form.create"),
            data: { component: "button", variant: "primary", size: "sm" } %>
      </div>
    </div>

    <%# Metadata row: source + tags %>
    <div class="shrink-0 flex flex-col gap-3 sm:flex-row sm:items-start sm:gap-4">
      <div class="sm:w-1/3 min-w-0" data-form-part="group">
        <%= form.label :source, data: { component: "label" } %>
        <%= form.text_field :source,
            placeholder: t("memories.form.source_placeholder"),
            autocomplete: "off",
            data: { component: "input" } %>
        <% if memory.errors[:source].any? %>
          <p data-form-part="error" class="text-destructive"><%= memory.errors[:source].first %></p>
        <% end %>
      </div>
      <div class="sm:w-1/4 min-w-0" data-form-part="group">
        <%= form.label :category, t("memories.form.category_label"), data: { component: "label" } %>
        <%= form.select :category,
            Memory::CATEGORIES.map { |c| [t("memories.categories.#{c}"), c] },
            { selected: memory.category.presence || Memory::DEFAULT_CATEGORY },
            data: { component: "input" } %>
        <% if memory.errors[:category].any? %>
          <p data-form-part="error" class="text-destructive"><%= memory.errors[:category].first %></p>
        <% end %>
      </div>
      <div class="flex-1 min-w-0" data-form-part="group">
        <%= form.label :tags, data: { component: "label" } %>
        <%= render "application/components/tag_input", form: form, field: :tags, value: memory.tags %>
      </div>
    </div>

    <%# Mobile action buttons — after metadata, before editor %>
    <div class="flex items-center gap-2 sm:hidden">
      <%= link_to t("memories.form.cancel"),
          memory.persisted? ? workspace_memory_path(workspace, memory) : workspace_path(workspace),
          data: { component: "button", variant: "outline", size: "sm" } %>
      <%= form.submit memory.persisted? ? t("memories.form.save") : t("memories.form.create"),
          data: { component: "button", variant: "primary", size: "sm" } %>
    </div>

    <%# Editor area: maquina-styled toolbar + House MD editor.
        Rendered with name="memory[content]" so the existing memory_params
        contract and JSON API stay unchanged. %>
    <div class="house-md-shell flex-1 min-h-0 flex flex-col rounded-md border border-border overflow-hidden">
      <%= render "shared/house_toolbar" %>
      <%# The editor adds its own inner .house-md-content contenteditable; these
          classes size/scroll the host. Content is read from the inner text. %>
      <%= tag.house_md memory.content&.body&.content.to_s,
          name: "memory[content]",
          toolbar: "house_toolbar",
          class: "flex-1 min-h-0 overflow-y-auto p-3 text-sm" %>
    </div>
  <% end %>
</div>
