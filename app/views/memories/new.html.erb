<%# locals: () %>

<%# The House MD editor is a Web Component with no Turbo awareness; skip the
    Turbo cache so a back/forward restore re-renders a fresh editor instead of
    re-running connectedCallback on cached DOM (which would duplicate the toolbar). %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<% content_for :page_title, "New Memory" %>

<% content_for :breadcrumb do %>
  <%= responsive_breadcrumbs(
    {
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace)
    },
    "New Memory",
    collapse_after: 2
  ) %>
<% end %>

<div class="mx-auto flex h-full w-full max-w-5xl flex-col">
  <div class="flex-1 min-h-0">
    <%= render "memories/form", memory: @memory, workspace: @workspace %>
  </div>
</div>
