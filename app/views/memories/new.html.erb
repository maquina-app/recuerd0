<%# locals: () %>

<% content_for :page_title, "New Memory" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Home" => root_path,
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace)
    },
    "New Memory"
  ) %>
<% end %>

<div class="mx-auto max-w-4xl h-[calc(100vh-12rem)] flex flex-col">
  <%= render "components/card", class_names: "flex flex-col flex-1 min-h-0" do %>
    <%= render "components/card_header" do %>
      <h2 class="text-2xl font-bold">Create New Memory</h2>
      <p class="text-sm text-muted-foreground">
        Add a new memory to <%= @workspace.name %>
      </p>
    <% end %>

    <%= render "components/card_content", class_names: "flex-1 flex flex-col min-h-0" do %>
      <%= render "memories/form", memory: @memory, workspace: @workspace %>
    <% end %>
  <% end %>
</div>
