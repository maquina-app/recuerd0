<%# locals: () %>

<% content_for :page_title, @memory.display_title %>

<% content_for :breadcrumb do %>
  <%= responsive_breadcrumbs(
    {
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace)
    },
    @memory.display_title,
    collapse_after: 2
  ) %>
<% end %>

<% is_pinned = @memory.pinned_by?(Current.user) %>
<% category_variant = {"decision" => :default, "discovery" => :secondary, "preference" => :warning, "general" => :outline}[@memory.category] || :outline %>
<% has_content = @memory.content&.body&.content.present? %>

<div class="mx-auto max-w-5xl overflow-x-clip">
  <%# ===== HEADER: tile + title + actions ===== %>
  <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex min-w-0 items-center gap-3.5">
      <div class="ws-tile">
        <%= icon_for(:file_text) %>
        <% if @workspace.active? && is_pinned %>
          <span class="ws-pin-dot">
            <%= icon_for(:pin_solid) %>
            <span class="sr-only"><%= t("memories.show.pinned_badge") %></span>
          </span>
        <% end %>
      </div>

      <h1 class="min-w-0 font-display text-2xl font-medium leading-[1.4] tracking-tight" style="overflow-wrap:anywhere;word-break:break-word"><%= @memory.display_title %></h1>
    </div>

    <%# action cluster %>
    <div class="flex flex-shrink-0 items-center gap-1 sm:ml-auto">
      <% if @workspace.active? && !@viewing_old_version %>
        <%= link_to edit_workspace_memory_path(@workspace, @memory), data: { component: "button", variant: "secondary", size: "sm" } do %>
          <%= icon_for(:edit, class: "size-4") %>
          <%= t("memories.memory_show_actions.edit") %>
        <% end %>
      <% end %>

      <% if has_content %>
        <div data-controller="clipboard">
          <textarea data-clipboard-target="source" class="hidden"><%= @memory.content.body.content %></textarea>
          <button type="button"
                  data-component="button" data-variant="ghost" data-size="icon-sm"
                  data-action="clipboard#copy"
                  aria-label="<%= t("memories.show.copy_markdown") %>"
                  title="<%= t("memories.show.copy_markdown") %>">
            <span data-clipboard-target="copyIcon"><%= icon_for(:copy, class: "size-4") %></span>
            <span data-clipboard-target="checkIcon" class="hidden"><%= icon_for(:check, class: "size-4") %></span>
          </button>
        </div>
      <% end %>

      <% if @workspace.active? %>
        <%= render "shared/pin_button", pinnable: @memory %>
      <% end %>

      <%= render "components/dropdown_menu", auto_close: true do %>
        <%= render "components/dropdown_menu/trigger", as_child: true do %>
          <button
            type="button"
            data-component="button"
            data-variant="ghost"
            data-size="icon-sm"
            data-dropdown-menu-target="trigger"
            data-action="dropdown-menu#toggle"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-label="Memory actions"
          >
            <%= icon_for(:more_vertical, class: "size-4") %>
          </button>
        <% end %>

        <%= render "components/dropdown_menu/content", align: :end, css_classes: "w-48" do %>
          <%= render "memories/memory_show_actions", memory: @memory, workspace: @workspace, viewing_old_version: @viewing_old_version %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ===== META (flush-left, aligned with tags + content) ===== %>
  <div class="mb-2 flex flex-wrap items-center gap-2">
    <%= render "components/badge", variant: category_variant, size: :sm do %>
      <span class="category-dot" data-cat="<%= @memory.category %>"></span>
      <%= t("memories.categories.#{@memory.category}") %>
    <% end %>

    <% if @memory.versioned? %>
      <%= render "components/badge", variant: :outline, size: :sm do %>
        <%= @memory.version_label %>
      <% end %>
    <% end %>

    <% if @memory.links_count > 0 %>
      <span class="mc-ind" title="<%= pluralize(@memory.links_count, "linked memory", "linked memories") %>">
        <%= icon_for(:link) %><%= @memory.links_count %>
      </span>
    <% end %>
  </div>

  <% if @memory.source.present? %>
    <div class="mc-source mb-2">
      <%= icon_for(:file_text) %>
      <span class="min-w-0">Source: <span class="src-val"><%= @memory.source %></span></span>
    </div>
  <% end %>

  <%# stat chips %>
  <div class="mb-5 flex flex-wrap items-center gap-x-4 gap-y-1.5">
    <span class="stat-chip" title="<%= @memory.created_at.strftime("%B %-d, %Y") %>">
      <%= icon_for(:clock) %>
      <%= t("memories.show.created_ago", time: time_ago_in_words(@memory.created_at)) %>
    </span>
    <span class="stat-chip" title="<%= @memory.updated_at.strftime("%B %-d, %Y at %-l:%M %p") %>">
      <%= icon_for(:refresh_cw) %>
      <%= t("memories.show.updated_ago", time: time_ago_in_words(@memory.updated_at)) %>
    </span>
    <% if @memory.versioned? %>
      <span class="stat-chip">
        <%= icon_for(:git_branch) %>
        <strong><%= @all_versions.size %></strong>
        <%= "version".pluralize(@all_versions.size) %>
      </span>
    <% end %>
    <% if @memory.links_count > 0 %>
      <span class="stat-chip">
        <%= icon_for(:link) %>
        <strong><%= @memory.links_count %></strong>
        <%= "link".pluralize(@memory.links_count) %>
      </span>
    <% end %>
  </div>

  <%# ===== STATE BANNERS ===== %>
  <% if @viewing_old_version %>
    <%= render "components/alert", variant: :default, icon: :git_branch, css_classes: "mb-5" do %>
      <%= render "components/alert/title", text: t("memories.show.old_version_title", version: @memory.version_label) %>
      <%= render "components/alert/description", text: t("memories.show.old_version_description") %>
    <% end %>
  <% end %>

  <% if @workspace.archived? %>
    <%= render "components/alert", variant: :default, icon: :archive, css_classes: "mb-5" do %>
      <%= render "components/alert/title", text: t("memories.show.archived_workspace_title") %>
      <%= render "components/alert/description", text: t("memories.show.archived_workspace_description") %>
    <% end %>
  <% elsif @workspace.deleted? %>
    <%= render "components/alert", variant: :warning, icon: :trash_2, css_classes: "mb-5" do %>
      <%= render "components/alert/title", text: t("memories.show.deleted_workspace_title") %>
      <%= render "components/alert/description", text: t("memories.show.deleted_workspace_description") %>
    <% end %>
  <% end %>

  <%# ===== TAGS + VERSION SWITCHER ===== %>
  <% if @memory.tags.any? || @memory.versioned? %>
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex flex-wrap gap-1.5">
        <% @memory.tags.each do |tag| %>
          <span class="tag-badge">
            <%= icon_for(:tag) %>
            <span class="tag-label"><%= tag %></span>
          </span>
        <% end %>
      </div>

      <% if @memory.versioned? %>
        <%= render "components/dropdown_menu", auto_close: true do %>
          <%= render "components/dropdown_menu/trigger", as_child: true do %>
            <button
              type="button"
              class="version-switch flex-shrink-0<%= " is-old" if @viewing_old_version %>"
              data-dropdown-menu-target="trigger"
              data-action="dropdown-menu#toggle"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-label="<%= t("memories.show.switch_version") %>"
            >
              <%= icon_for(:git_branch) %>
              <span class="vs-label"><%= @memory.version_label %></span>
              <span class="vs-tag">· <%= @memory.current_version? ? t("memories.show.current_label") : t("memories.show.older_label") %></span>
              <%= icon_for(:chevron_down) %>
            </button>
          <% end %>

          <%= render "components/dropdown_menu/content", align: :end, css_classes: "w-44" do %>
            <% @all_versions.each do |version| %>
              <%= render "components/dropdown_menu/item", href: workspace_memory_path(@workspace, version) do %>
                <%= icon_for(:git_branch, class: "size-4") %>
                <span><%= version.version_label %></span>
                <% if version.current_version? %>
                  <span class="ml-auto text-xs text-muted-foreground"><%= t("memories.show.current_label") %></span>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ===== CONTENT — reading panel ===== %>
  <% if has_content %>
    <%= render "components/card" do %>
      <%= render "components/card/content" do %>
        <div class="memory-content">
          <%= sanitize_content @memory.content.body.to_html %>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <%= render "components/empty", variant: :outline do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :file_text %>
        <%= render "components/empty/title", text: t("memories.show.no_content_title") %>
        <%= render "components/empty/description", text: t("memories.show.no_content_description") %>
      <% end %>
      <% if @workspace.active? %>
        <%= render "components/empty/content" do %>
          <%= link_to edit_workspace_memory_path(@workspace, @memory), data: { component: "button", variant: "secondary" } do %>
            <%= icon_for(:edit, class: "size-4") %>
            <%= t("memories.show.add_content") %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%# ===== RELATED MEMORIES ===== %>
  <% if @memory.links_count > 0 %>
    <section class="mt-8" id="related-memories">
      <div class="ws-group-label mb-3"><%= t("memories.show.related_memories") %></div>
      <div class="divide-y divide-border overflow-hidden rounded-lg border border-border">
        <% @memory.linked_memories.latest_versions.includes(:workspace).order(updated_at: :desc).each do |linked| %>
          <% linked_cat = Memory::CATEGORIES.include?(linked.category) ? linked.category : "general" %>
          <div class="memory-row">
            <span class="category-dot" data-cat="<%= linked_cat %>" title="<%= t("memories.categories.#{linked_cat}") %>"></span>
            <%= link_to linked.display_title, workspace_memory_path(linked.workspace, linked), class: "mr-title flex-1" %>
            <span class="flex-shrink-0 text-xs text-muted-foreground">
              <%= t("memories.show.related_in") %>
              <%= link_to linked.workspace.name, workspace_path(linked.workspace), class: "hover:underline" %>
            </span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# ===== VERSIONS ===== %>
  <% if @memory.versioned? %>
    <section class="mt-8">
      <div class="ws-group-label mb-3"><%= t("memories.show.versions_label") %></div>
      <%= render "components/card" do %>
        <%= render "components/card/content" do %>
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
              <span><%= t("memories.show.current_version_html", version: @memory.version_label) %></span>
              <% if @memory.child_versions.any? %>
                <span class="text-muted-foreground"><%= t("memories.show.child_versions_count", count: @memory.child_versions.count) %></span>
              <% end %>
            </div>
            <%= link_to workspace_memory_versions_path(@workspace, @memory), data: { component: "button", variant: "ghost", size: "sm" } do %>
              <%= icon_for(:git_branch, class: "size-4") %>
              <%= t("memories.show.view_all_versions") %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <%# Scroll to top — custom styled (not a gem button component) for circular FAB appearance %>
  <div data-controller="scroll-to-top">
    <button
      type="button"
      data-scroll-to-top-target="button"
      data-action="scroll-to-top#scrollToTop"
      class="hidden fixed bottom-6 right-6 z-50 h-10 w-10 rounded-full border border-border bg-background text-primary shadow-lg transition-opacity hover:bg-muted cursor-pointer"
      aria-label="Scroll to top"
    >
      <%= icon_for(:chevron_up, class: "size-5 mx-auto") %>
    </button>
  </div>
</div>
