<%# locals: () %>

<% content_for :page_title, @memory.display_title %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace)
    },
    @memory.display_title
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <%# Header %>
  <div class="mb-6 flex items-center justify-between">
    <div class="min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-2xl font-bold tracking-tight"><%= @memory.display_title %></h1>

        <% if @memory.has_versions? %>
          <%= render "components/badge", variant: :outline do %>
            <%= @memory.version_label %>
          <% end %>
        <% end %>

        <% if @memory.pinned_by?(Current.user) %>
          <%= render "components/badge", variant: :secondary do %>
            <%= icon_for(:pin, class: "size-3") %>
            Pinned
          <% end %>
        <% end %>
      </div>

      <% if @memory.source.present? %>
        <p class="text-muted-foreground mt-1"><%= @memory.source %></p>
      <% end %>
    </div>

    <div class="flex items-center gap-1 flex-shrink-0">
      <% if @memory.has_versions? %>
        <select
          data-controller="navigate"
          data-action="change->navigate#visit"
          data-component="input"
          class="w-auto text-sm"
          aria-label="Switch version"
        >
          <% @all_versions.each do |version| %>
            <option
              value="<%= workspace_memory_path(@workspace, version) %>"
              <%= "selected" if version == @memory %>
            >
              <%= version.version_label %><%= " (current)" if version == @memory %>
            </option>
          <% end %>
        </select>
      <% end %>

      <% if @workspace.active? %>
        <%= render "shared/pin_button", pinnable: @memory %>
      <% end %>

      <%= render "components/dropdown_menu" do %>
        <%= render "components/dropdown_menu/trigger", as_child: true do %>
          <button
            type="button"
            data-component="button"
            data-variant="ghost"
            data-size="icon-sm"
            data-dropdown-menu-target="trigger"
            data-action="dropdown-menu#toggle"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-label="Memory actions"
          >
            <%= icon_for(:more_vertical, class: "size-4") %>
          </button>
        <% end %>

        <%= render "components/dropdown_menu/content",
            align: :end,
            css_classes: "w-48" do %>
          <%= render "memories/memory_show_actions", memory: @memory, workspace: @workspace %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# State alerts %>
  <% if @workspace.archived? %>
    <%= render "components/alert", variant: :default, icon: :archive, css_classes: "mb-6" do %>
      <%= render "components/alert/title", text: "This memory is in an archived workspace" %>
      <%= render "components/alert/description", text: "This workspace is in read-only mode. You can view its contents but cannot make changes." %>
    <% end %>
  <% elsif @workspace.deleted? %>
    <%= render "components/alert", variant: :warning, icon: :trash_2, css_classes: "mb-6" do %>
      <%= render "components/alert/title", text: "This memory is in a deleted workspace" %>
      <%= render "components/alert/description", text: "This workspace has been deleted and is in read-only mode. Restore the workspace to continue editing." %>
    <% end %>
  <% end %>

  <%# Metadata %>
  <div class="flex items-center gap-4 text-sm text-muted-foreground mb-4 flex-wrap">
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:clock, class: "size-4") %>
      Created <%= time_ago_in_words(@memory.created_at) %> ago
    </span>
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:refresh_cw, class: "size-4") %>
      Updated <%= time_ago_in_words(@memory.updated_at) %> ago
    </span>
    <% if @memory.has_versions? %>
      <span class="inline-flex items-center gap-1">
        <%= icon_for(:git_branch, class: "size-4") %>
        <%= @memory.version_label %> of <%= pluralize(@all_versions.size, "version") %>
      </span>
    <% end %>
  </div>

  <% if @memory.tags.any? %>
    <div class="flex flex-wrap gap-2 mb-4">
      <% @memory.tags.each do |tag| %>
        <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
          <%= icon_for(:tag, class: "size-3") %>
          <%= tag %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="mb-6">
    <%= render "components/separator" %>
  </div>

  <%# Content %>
  <% if @memory.content&.body.present? %>
    <div class="prose max-w-none dark:prose-invert">
      <%= render_markdown(@memory.content.body) %>
    </div>
  <% else %>
    <%= render "components/empty", variant: :outline do %>
      <%= render "components/empty/header" do %>
        <%= render "components/empty/media", icon: :file_text %>
        <%= render "components/empty/title", text: "No content yet" %>
        <%= render "components/empty/description" do %>
          This memory doesn't have any content. Add some markdown content to get started.
        <% end %>
      <% end %>
      <% if @workspace.active? %>
        <%= render "components/empty/content" do %>
          <%= link_to edit_workspace_memory_path(@workspace, @memory), data: { component: "button", variant: "secondary" } do %>
            <%= icon_for(:edit, class: "size-4") %>
            Add Content
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%# Version info %>
  <% if @memory.has_versions? %>
    <div class="mt-6">
      <%= render "components/separator" %>
    </div>

    <div class="mt-6">
      <%= render "components/card" do %>
        <%= render "components/card/header", layout: :row do %>
          <%= render "components/card/title", text: "Version Information" %>
          <%= render "components/card/action" do %>
            <%= link_to workspace_memory_versions_path(@workspace, @memory),
                data: { component: "button", variant: "ghost", size: "sm" } do %>
              <%= icon_for(:git_branch, class: "size-4") %>
              View All Versions
            <% end %>
          <% end %>
        <% end %>

        <%= render "components/card/content" do %>
          <div class="flex items-center gap-4 text-sm">
            <span>Current: <strong><%= @memory.version_label %></strong></span>
            <% if @memory.child_versions.any? %>
              <span class="text-muted-foreground">
                <%= pluralize(@memory.child_versions.count, "version") %> created from this
              </span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Scroll to top — custom styled (not a gem button component) for circular FAB appearance %>
  <div data-controller="scroll-to-top">
    <button
      type="button"
      data-scroll-to-top-target="button"
      data-action="scroll-to-top#scrollToTop"
      class="hidden fixed bottom-6 right-6 z-50 h-10 w-10 rounded-full border border-border bg-background text-primary shadow-lg transition-opacity hover:bg-muted cursor-pointer"
      aria-label="Scroll to top"
    >
      <%= icon_for(:chevron_up, class: "size-5 mx-auto") %>
    </button>
  </div>
</div>
