<%# locals: () %>

<% content_for :page_title, @memory.display_title %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Home" => root_path,
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace)
    },
    @memory.display_title
  ) %>
<% end %>

<div class="mx-auto max-w-4xl space-y-6">
  <%# Workspace state alert %>
  <% unless @workspace.active? %>
    <%= render "components/alert", variant: :warning, css_classes: "mb-6" do %>
      <div class="flex items-start gap-3">
        <%= icon_for(:alert_triangle, class: "w-4 h-4 flex-shrink-0 text-amber-600 dark:text-amber-400") %>
        <div>
          <strong>Read-only mode</strong>
          <p class="mt-1">This memory is in a <%= @workspace.archived? ? "archived" : "deleted" %> workspace and cannot be edited.</p>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# Memory header %>
  <div class="flex justify-between items-start gap-4">
    <div class="space-y-2 flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-3xl font-bold"><%= @memory.display_title %></h1>

        <% if @memory.has_versions? %>
          <%= render "components/badge", variant: :outline do %>
            <%= @memory.version_label %>
          <% end %>
        <% end %>

        <% if @memory.pinned_by?(Current.user) %>
          <%= render "components/badge", variant: :secondary do %>
            <%= icon_for(:pin, class: "w-3 h-3") %>
            Pinned
          <% end %>
        <% end %>
      </div>

      <% if @memory.source.present? %>
        <p class="text-muted-foreground">
          Source: <%= @memory.source %>
        </p>
      <% end %>
    </div>

    <%# Action buttons %>
    <div class="flex items-center gap-2 flex-shrink-0">
      <%= render "shared/pin_button", pinnable: @memory %>

      <% if @memory.has_versions? %>
        <%= link_to workspace_memory_versions_path(@workspace, @memory),
            class: "btn-ghost btn-sm",
            title: "View version history" do %>
          <%= icon_for(:git_branch, class: "w-4 h-4") %>
          Versions
        <% end %>
      <% end %>

      <% if @workspace.active? %>
        <%= button_to workspace_memory_versions_path(@workspace, @memory),
            method: :post,
            class: "btn-secondary btn-sm",
            title: "Create a new version",
            data: { turbo_confirm: "Create a new version from #{@memory.version_label}?" } do %>
          <%= icon_for(:copy_plus, class: "w-4 h-4") %>
          New Version
        <% end %>
        <%= link_to edit_workspace_memory_path(@workspace, @memory),
            class: "btn-ghost btn-sm",
            title: "Edit this memory" do %>
          <%= icon_for(:edit, class: "w-4 h-4") %>
          Edit
        <% end %>
        <%= button_to workspace_memory_path(@workspace, @memory),
            method: :delete,
            class: "btn-ghost btn-sm text-destructive hover:text-destructive",
            title: "Delete this memory",
            data: { turbo_confirm: "Are you sure you want to delete this memory?" } do %>
          <%= icon_for(:trash_2, class: "w-4 h-4") %>
          Delete
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Content %>
  <%= render "components/card" do %>
    <div class="p-6">
      <% content_body = @memory.content&.body %>
      <% if content_body.present? %>
        <div
          class="
            prose prose-sm max-w-none dark:prose-invert max-h-[600px]
            overflow-y-auto
          "
        >
          <!-- class: "whitespace-pre-wrap break-words" -->
          <%= Commonmarker.parse(content_body, options: { parse: { smart: true } }).to_html.html_safe %>
        </div>
      <% else %>
        <%# Empty state with minimum height %>
        <div
          class="
            min-h-[300px] flex flex-col items-center justify-center
            text-center py-12
          "
        >
          <%= icon_for(:file_text, class: "w-12 h-12 mx-auto text-muted-foreground/50 mb-4") %>
          <h3 class="text-lg font-semibold text-muted-foreground mb-2">
            No content yet
          </h3>

          <p class="text-sm text-muted-foreground mb-6 max-w-sm">
            This memory doesn't have any content. Add some markdown content to
            get started.
          </p>

          <% if @workspace.active? %>
            <%= link_to edit_workspace_memory_path(@workspace, @memory),
                class: "btn-secondary" do %>
              <%= icon_for(:edit, class: "w-4 h-4") %>
              Add Content
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @memory.tags.any? %>
      <%= render "components/card/footer" do %>
        <div class="flex flex-wrap gap-2">
          <% @memory.tags.each do |tag| %>
            <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
              <%= icon_for(:tag, class: "w-3 h-3") %>
              <%= tag %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%# Metadata %>
  <div class="text-sm text-muted-foreground flex items-center gap-4 flex-wrap">
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:clock, class: "w-4 h-4") %> Created <%= time_ago_in_words(@memory.created_at) %> ago
    </span>
    <span class="inline-flex items-center gap-1">
      <%= icon_for(:refresh_cw, class: "w-4 h-4") %> Updated <%= time_ago_in_words(@memory.updated_at) %> ago
    </span>
  </div>

  <%# Version info %>
  <% if @memory.has_versions? %>
    <%= render "components/card" do %>
      <%= render "components/card/header" do %>
        <div class="flex justify-between items-center">
          <h3 class="text-lg font-semibold">Version Information</h3>
          <%= link_to workspace_memory_versions_path(@workspace, @memory),
              class: "btn-ghost btn-sm" do %>
            <%= icon_for(:git_branch, class: "w-4 h-4") %>
            View All Versions
          <% end %>
        </div>
      <% end %>

      <%= render "components/card/content" do %>
        <div class="flex items-center gap-4 text-sm">
          <span>Current: <strong><%= @memory.version_label %></strong></span>
          <% if @memory.child_versions.any? %>
            <span class="text-muted-foreground">
              <%= pluralize(@memory.child_versions.count, "version") %> created from this
            </span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
