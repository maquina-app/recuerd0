<%# locals: (memory:, workspace:, show_pinned: false) %>

<%= render "components/card", css_classes: "group hover:shadow-md transition-shadow" do %>
  <%= render "components/card/header", layout: :row do %>
    <div class="space-y-1 flex-1">
      <div class="flex items-center gap-2">
        <%= render "components/card/title", text: memory.display_title %>

        <% if memory.has_versions? %>
          <%= render "components/badge", variant: :outline, css_classes: "text-xs" do %>
            <%= memory.version_label %>
          <% end %>
        <% end %>

        <% if show_pinned || memory.pinned_by?(Current.user) %>
          <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
            <%= icon_for(:pin, class: "w-3 h-3") %>
            Pinned
          <% end %>
        <% end %>
      </div>
      <% if memory.source.present? %>
        <p class="text-sm text-muted-foreground">
          Source: <%= memory.source %>
        </p>
      <% end %>
    </div>

    <%= render "components/card/action", css_classes: "opacity-0 group-hover:opacity-100 transition-opacity" do %>
      <%= render "components/dropdown_menu", auto_close: true do %>
        <%= render "components/dropdown_menu/trigger", as_child: true do %>
          <button
            type="button"
            data-component="button"
            data-variant="ghost"
            data-size="icon-sm"
            data-dropdown-menu-target="trigger"
            data-action="dropdown-menu#toggle"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-label="Memory actions"
          >
            <%= icon_for(:more_vertical, class: "w-4 h-4") %>
          </button>
        <% end %>

        <%= render "components/dropdown_menu/content",
            align: :end,
            css_classes: "w-48" do %>
          <%= render "memories/memory_actions", memory: memory, workspace: workspace %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render "components/card/content" do %>
    <div class="prose prose-sm max-w-none text-muted-foreground">
      <%= truncate(memory.content&.body || "", length: 200) %>
    </div>

    <% if memory.tags.any? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% memory.tags.each do |tag| %>
          <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
            <%= icon_for(:tag, class: "w-3 h-3") %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card/footer" do %>
    <div class="flex justify-between items-center w-full text-xs text-muted-foreground">
      <span class="inline-flex items-center gap-1">
        <%= icon_for(:clock, class: "w-3 h-3 flex-shrink-0") %>
        Updated
        <%= time_ago_in_words(memory.updated_at) %>
        ago
      </span>
      <%= link_to workspace_memory_path(workspace, memory),
          class: "inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors" do %>
        <%= t("memories.memory.view_details") %>
        <%= icon_for(:chevron_right, class: "w-3 h-3 flex-shrink-0 transition-transform group-hover:translate-x-0.5") %>
      <% end %>
    </div>
  <% end %>
<% end %>
