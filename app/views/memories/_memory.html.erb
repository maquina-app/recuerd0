<%# locals: (memory:, workspace:, show_pinned: false) %>
<% display_version = memory.versioned? ? memory.current_version : memory %>
<% category_variant = { "decision" => :default, "discovery" => :secondary, "preference" => :warning, "general" => :outline }[display_version.category] || :outline %>
<% is_pinned = show_pinned || memory.pinned_by?(Current.user) %>

<%= render "components/card", css_classes: "memory-card group hover:shadow-md transition-shadow" do %>
  <%= render "components/card/header" do %>
    <div class="flex items-start justify-between gap-2">
      <div class="mc-title min-w-0">
        <%= link_to display_version.display_title, workspace_memory_path(workspace, display_version) %>
      </div>

      <div class="flex flex-shrink-0 items-center gap-1.5">
        <% if workspace.active? && is_pinned %>
          <span class="inline-flex text-primary" title="<%= t("workspaces.show.pinned_badge") %>">
            <%= icon_for(:pin, class: "size-3.5") %>
            <span class="sr-only"><%= t("workspaces.show.pinned_badge") %></span>
          </span>
        <% end %>

        <%= render "components/dropdown_menu", auto_close: true do %>
          <%= render "components/dropdown_menu/trigger", as_child: true do %>
            <button
              type="button"
              data-component="button"
              data-variant="ghost"
              data-size="icon-sm"
              data-dropdown-menu-target="trigger"
              data-action="dropdown-menu#toggle"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-label="Memory actions"
            >
              <%= icon_for(:more_vertical, class: "size-4") %>
            </button>
          <% end %>

          <%= render "components/dropdown_menu/content", align: :end, css_classes: "w-48" do %>
            <%= render "memories/memory_actions", memory: memory, workspace: workspace %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="mc-meta">
      <%= render "components/badge", variant: category_variant, size: :sm do %>
        <span class="category-dot" data-cat="<%= display_version.category %>"></span>
        <%= t("memories.categories.#{display_version.category}") %>
      <% end %>

      <% if memory.versioned? %>
        <span class="mc-ind" title="<%= display_version.version_label %>">
          <%= icon_for(:git_branch) %><%= display_version.version_label %>
        </span>
      <% end %>

      <% if memory.links_count > 0 %>
        <span class="mc-ind" title="<%= pluralize(memory.links_count, "linked memory", "linked memories") %>">
          <%= icon_for(:link) %><%= memory.links_count %>
        </span>
      <% end %>
    </div>

    <% if display_version.source.present? %>
      <div class="mc-source">
        <%= icon_for(:file_text) %>
        <span class="min-w-0">Source: <span class="src-val"><%= display_version.source %></span></span>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card/content" do %>
    <% plain = display_version.content&.plain_text.to_s.gsub(/\n{3,}/, "\n\n").strip %>
    <p class="excerpt-clamp"><%= truncate(plain, length: 200, omission: "...") %></p>

    <% if display_version.tags.any? %>
      <div class="flex flex-wrap gap-1.5 pt-3">
        <% display_version.tags.each do |tag| %>
          <span class="tag-badge">
            <%= icon_for(:tag) %>
            <span class="tag-label"><%= tag %></span>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card/footer", align: :between do %>
    <span class="stat-chip" title="<%= t("memories.show.updated_ago", time: time_ago_in_words(memory.updated_at)) %>">
      <%= icon_for(:clock) %>
      <%= t("memories.show.updated_ago", time: time_ago_in_words(memory.updated_at)) %>
    </span>
    <%= link_to workspace_memory_path(workspace, display_version), class: "mc-detail" do %>
      <%= t("memories.memory.view_details") %>
      <%= icon_for(:chevron_right) %>
    <% end %>
  <% end %>
<% end %>
