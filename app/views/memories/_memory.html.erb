<%# locals: (memory:, workspace:, show_pinned: false) %>

<%= render "components/card", css_classes: "hover:shadow-md transition-shadow" do %>
  <%= render "components/card/header" do %>
    <div class="flex justify-between items-start">
      <div class="space-y-1 flex-1">
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold leading-none tracking-tight">
            <%= memory.display_title %>
          </h3>

          <% if memory.has_versions? %>
            <%= render "components/badge", variant: :outline, css_classes: "text-xs" do %>
              <%= memory.version_label %>
            <% end %>
          <% end %>

          <% if show_pinned || memory.pinned_by?(Current.user) %>
            <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
              <%= icon_for(:pin, class: "w-3 h-3") %>
              Pinned
            <% end %>
          <% end %>
        </div>
        <% if memory.source.present? %>
          <p class="text-sm text-muted-foreground">
            Source: <%= memory.source %>
          </p>
        <% end %>
      </div>

      <div class="flex items-center gap-1 ml-4">
        <%# Pin button %>
        <%= render "shared/pin_button", pinnable: memory %>

        <%# Version controls %>
        <% if memory.has_versions? %>
          <%= link_to workspace_memory_versions_path(workspace, memory),
              class: "btn-ghost btn-icon-sm",
              title: "View versions" do %>
            <%= icon_for(:git_branch, class: "w-4 h-4") %>
          <% end %>
        <% end %>

        <% if workspace.active? %>
          <%= link_to edit_workspace_memory_path(workspace, memory),
              class: "btn-ghost btn-icon-sm",
              title: "Edit memory" do %>
            <%= icon_for(:edit, class: "w-4 h-4") %>
          <% end %>
          <%= button_to workspace_memory_path(workspace, memory),
              method: :delete,
              data: { turbo_confirm: "Are you sure you want to delete this memory?" },
              class: "btn-ghost btn-icon-sm text-destructive hover:text-destructive",
              title: "Delete memory" do %>
            <%= icon_for(:trash_2, class: "w-4 h-4") %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "components/card/content" do %>
    <div class="prose prose-sm max-w-none text-muted-foreground">
      <%= truncate(memory.content&.body || "", length: 200) %>
    </div>

    <% if memory.tags.any? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% memory.tags.each do |tag| %>
          <%= render "components/badge", variant: :secondary, css_classes: "text-xs" do %>
            <%= icon_for(:tag, class: "w-3 h-3") %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card/footer" do %>
    <div class="flex justify-between items-center w-full text-xs text-muted-foreground">
      <span class="inline-flex items-center gap-1">
        <%= icon_for(:clock, class: "w-3 h-3 flex-shrink-0") %>
        Updated
        <%= time_ago_in_words(memory.updated_at) %>
        ago
      </span>
      <%= link_to workspace_memory_path(workspace, memory),
          class: "btn-link text-xs p-0 h-auto inline-flex items-center gap-1" do %>
        View Details
        <%= icon_for(:chevron_right, class: "w-3 h-3 flex-shrink-0") %>
      <% end %>
    </div>
  <% end %>
<% end %>
