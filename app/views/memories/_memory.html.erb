<%= render "components/card", class_names: "hover:shadow-md transition-shadow" do %>
  <%= render "components/card_header" do %>
    <div class="flex justify-between items-start">
      <div class="space-y-1">
        <h3 class="text-lg font-semibold leading-none tracking-tight">
          <%= memory.title.presence || "Untitled Memory" %>
        </h3>
        <% if memory.source.present? %>
          <p class="text-sm text-muted-foreground">
            Source:
            <%= memory.source %>
          </p>
        <% end %>
      </div>
      <div class="flex gap-2">
        <%= link_to "Edit",
        edit_workspace_memory_path(workspace, memory),
        class: "text-sm text-muted-foreground hover:text-foreground" %>
        <%= button_to "Delete",
        workspace_memory_path(workspace, memory),
        method: :delete,
        data: {
          turbo_confirm: "Are you sure?",
        },
        class: "text-sm text-destructive hover:text-destructive/90" %>
      </div>
    </div>
  <% end %>

  <%= render "components/card_content" do %>
    <div class="prose prose-sm max-w-none">
      <%= truncate(memory.content.body, length: 200) %>
    </div>

    <% if memory.tags.any? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% memory.tags.each do |tag| %>
          <%= render "components/badge", variant: "secondary" do %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card_footer" do %>
    <div
      class="
        flex justify-between items-center w-full text-xs text-muted-foreground
      "
    >
      <span>Created
        <%= time_ago_in_words(memory.created_at) %>
        ago</span>
      <%= link_to "View Details",
      workspace_memory_path(workspace, memory),
      class: "hover:text-foreground" %>
    </div>
  <% end %>
<% end %>
