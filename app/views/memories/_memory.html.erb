<%= render "components/card", class_names: "hover:shadow-md transition-shadow" do %>
  <%= render "components/card_header" do %>
    <div class="flex justify-between items-start">
      <div class="space-y-1 flex-1">
        <h3 class="text-lg font-semibold leading-none tracking-tight">
          <%= memory.title.presence || "Untitled Memory" %>
        </h3>
        <% if memory.source.present? %>
          <p class="text-sm text-muted-foreground">
            Source:
            <%= memory.source %>
          </p>
        <% end %>
      </div>
      <div class="flex items-center gap-1 ml-4">
        <%= link_to edit_workspace_memory_path(workspace, memory),
            class: "btn-ghost btn-icon-sm",
            title: "Edit memory" do %>
          <%= lucide_icon(:edit, size: "w-4 h-4") %>
        <% end %>
        <%= button_to workspace_memory_path(workspace, memory),
            method: :delete,
            data: { turbo_confirm: "Are you sure you want to delete this memory?" },
            class: "btn-ghost btn-icon-sm text-destructive hover:text-destructive",
            title: "Delete memory" do %>
          <%= lucide_icon(:trash_2, size: "w-4 h-4") %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "components/card_content" do %>
    <div class="prose prose-sm max-w-none text-muted-foreground">
      <%= truncate(memory.content.body, length: 200) %>
    </div>

    <% if memory.tags.any? %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% memory.tags.each do |tag| %>
          <%= render "components/badge", variant: "secondary" do %>
            <%= lucide_icon(:tag, size: "w-3 h-3") %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card_footer" do %>
    <div
      class="
        flex justify-between items-center w-full text-xs text-muted-foreground
      "
    >
      <span>
        <%= lucide_icon(:clock, size: "w-3 h-3", class: "inline") %>
        Created
        <%= time_ago_in_words(memory.created_at) %>
        ago
      </span>
      <%= link_to workspace_memory_path(workspace, memory),
          class: "btn-link text-xs p-0 h-auto" do %>
        View Details
        <%= lucide_icon(:chevron_right, size: "w-3 h-3", class: "inline ml-1") %>
      <% end %>
    </div>
  <% end %>
<% end %>
