<%# locals: () %>

<% content_for :page_title, "Edit #{@memory.display_title}" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Home" => root_path,
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace),
      @memory.display_title => workspace_memory_path(@workspace, @memory)
    },
    "Edit"
  ) %>
<% end %>

<div class="mx-auto max-w-4xl h-[calc(100vh-12rem)] flex flex-col space-y-6">
  <%# Warning for child versions %>
  <% unless @memory.latest_version? %>
    <%= render "components/alert", variant: :warning do %>
      <div class="flex items-start gap-3">
        <%= icon_for(:info, class: "w-4 h-4 flex-shrink-0 text-amber-600 dark:text-amber-400") %>
        <div>
          <strong>Editing a child version</strong>
          <p class="mt-1">You're editing <%= @memory.version_label %>. Changes will update this version directly. Consider creating a new version instead to preserve history.</p>
          <div class="mt-3">
            <%= button_to workspace_memory_versions_path(@workspace, @memory),
                method: :post,
                data: { turbo_confirm: "Create a new version from #{@memory.version_label}?" },
                class: "btn-secondary btn-sm" do %>
              <%= icon_for(:copy_plus, class: "w-4 h-4") %>
              Create New Version Instead
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render "components/card", css_classes: "flex flex-col flex-1 min-h-0" do %>
    <%= render "components/card/header" do %>
      <h2 class="text-2xl font-bold">Edit Memory</h2>
      <p class="text-sm text-muted-foreground">
        Make changes to <%= @memory.display_title %>
      </p>
    <% end %>

    <%= render "components/card/content", css_classes: "flex-1 flex flex-col min-h-0" do %>
      <%= render "memories/form", memory: @memory, workspace: @workspace %>
    <% end %>
  <% end %>
</div>
