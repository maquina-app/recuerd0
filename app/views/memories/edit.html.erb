<%# locals: () %>

<% content_for :page_title, "Edit #{@memory.display_title}" %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {
      "Workspaces" => workspaces_path,
      @workspace.name => workspace_path(@workspace),
      @memory.display_title => workspace_memory_path(@workspace, @memory)
    },
    "Edit"
  ) %>
<% end %>

<div class="h-full flex flex-col">
  <% unless @memory.root_version? %>
    <div class="shrink-0 mb-3">
      <%= render "components/alert", variant: :warning, icon: :info, css_classes: "py-2" do %>
        <p class="text-sm">
          Editing <%= @memory.version_label %> — changes update this version directly.
          <%= button_to workspace_memory_versions_path(@workspace, @memory),
              method: :post,
              class: "inline-flex items-center gap-1 underline font-medium ml-1",
              data: { turbo_confirm: "Create a new version from #{@memory.version_label}?" } do %>
            Create new version instead
          <% end %>
        </p>
      <% end %>
    </div>
  <% end %>

  <div class="flex-1 min-h-0">
    <%= render "memories/form", memory: @memory, workspace: @workspace %>
  </div>
</div>
