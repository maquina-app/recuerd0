<%# locals: () %>
<% content_for :page_title, t(".title") %>

<% content_for :breadcrumb do %>
  <%= breadcrumbs(
    {},
    t(".title"),
  ) %>
<% end %>

<div class="mx-auto max-w-4xl">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="font-display text-2xl font-medium tracking-tight"><%= t(".title") %></h1>
  </div>

  <%= render "components/alert", variant: :default, icon: :pin, css_classes: "mb-6" do %>
    <strong><%= t("memories.pinned.index.about_title") %></strong>
    <p class="mt-1"><%= t("memories.pinned.index.about_description") %></p>
  <% end %>

  <% if @memories.any? %>
    <div class="grid gap-4">
      <% @memories.each do |memory| %>
        <div>
          <p class="text-xs text-muted-foreground mb-1">
            <%= icon_for(:folders, class: "w-3 h-3 inline") %>
            <%= link_to memory.workspace.name, workspace_path(memory.workspace), class: "hover:underline" %>
          </p>
          <%= render "memories/memory", memory: memory, workspace: memory.workspace, show_pinned: true %>
        </div>
      <% end %>
    </div>

    <%= pagination_nav(@pagy, :pinned_memories_path) %>
  <% else %>
    <%= render "workspaces/empty_state_generic", icon: :pin, title: t(".empty_title"), description: t(".empty_description") %>
  <% end %>
</div>
