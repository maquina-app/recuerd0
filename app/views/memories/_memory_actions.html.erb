<%# locals: (memory:, workspace:) -%>
<%= render "components/dropdown_menu/item",
    href: workspace_memory_path(workspace, memory) do %>
  <%= icon_for(:file_text, class: "w-4 h-4") %>
  Open
<% end %>

<% if memory.pinned_by?(Current.user) %>
  <%= render "components/dropdown_menu/item",
      href: destroy_pin_path(pinnable_type: memory.class.name, pinnable_id: memory.id),
      data: { turbo_method: :delete, turbo_stream: true } do %>
    <%= icon_for(:pin, class: "w-4 h-4") %>
    Unpin
  <% end %>
<% else %>
  <%= render "components/dropdown_menu/item",
      href: create_pin_path(pinnable_type: memory.class.name, pinnable_id: memory.id),
      data: { turbo_method: :post, turbo_stream: true } do %>
    <%= icon_for(:pin, class: "w-4 h-4") %>
    Pin
  <% end %>
<% end %>

<% if memory.has_versions? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_versions_path(workspace, memory) do %>
    <%= icon_for(:git_branch, class: "w-4 h-4") %>
    Versions
  <% end %>
<% end %>

<% if workspace.active? %>
  <%= render "components/dropdown_menu/separator" %>

  <%= render "components/dropdown_menu/item",
      href: edit_workspace_memory_path(workspace, memory) do %>
    <%= icon_for(:edit, class: "w-4 h-4") %>
    Edit
  <% end %>

  <%= render "components/dropdown_menu/item",
      href: workspace_memory_path(workspace, memory),
      css_classes: "text-destructive focus:text-destructive",
      data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this memory?" } do %>
    <%= icon_for(:trash_2, class: "w-4 h-4") %>
    Delete
  <% end %>
<% end %>
