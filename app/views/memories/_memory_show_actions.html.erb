<%# locals: (memory:, workspace:) -%>
<% if memory.content&.body.present? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_markdown_path(workspace, memory),
      target: "_blank" do %>
    <%= icon_for(:file_text, class: "size-4") %>
    <%= t("memories.show.view_markdown") %>
  <% end %>
  <%= render "components/dropdown_menu/separator" %>
<% end %>

<% if memory.versioned? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_versions_path(workspace, memory) do %>
    <%= icon_for(:git_branch, class: "size-4") %>
    <%= t("memories.memory_show_actions.versions") %>
  <% end %>
<% end %>

<% if workspace.active? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_versions_path(workspace, memory),
      method: :post,
      data: { turbo_confirm: t("memories.memory_show_actions.new_version_confirm", version: memory.version_label) } do %>
    <%= icon_for(:copy_plus, class: "size-4") %>
    <%= t("memories.memory_show_actions.new_version") %>
  <% end %>

  <%= render "components/dropdown_menu/separator" %>

  <%= render "components/dropdown_menu/item",
      href: edit_workspace_memory_path(workspace, memory) do %>
    <%= icon_for(:edit, class: "size-4") %>
    <%= t("memories.memory_show_actions.edit") %>
  <% end %>

  <% if memory.versioned? %>
    <%= render "components/dropdown_menu/item",
        href: workspace_memory_version_consolidation_path(workspace, memory, memory),
        method: :post,
        variant: :destructive,
        data: { turbo_confirm: t("memories.memory_show_actions.delete_other_versions_confirm", version: memory.version_label) } do %>
      <%= icon_for(:trash_2, class: "size-4") %>
      <%= t("memories.memory_show_actions.delete_other_versions") %>
    <% end %>
  <% end %>

  <%= render "components/dropdown_menu/separator" %>

  <%= render "components/dropdown_menu/item",
      href: workspace_memory_path(workspace, memory),
      method: :delete,
      variant: :destructive,
      data: { turbo_confirm: t("memories.memory_show_actions.delete_confirm") } do %>
    <%= icon_for(:trash_2, class: "size-4") %>
    <%= t("memories.memory_show_actions.delete") %>
  <% end %>
<% end %>
