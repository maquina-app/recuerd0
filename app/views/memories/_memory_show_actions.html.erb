<%# locals: (memory:, workspace:) -%>
<% if memory.has_versions? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_versions_path(workspace, memory) do %>
    <%= icon_for(:git_branch, class: "size-4") %>
    Versions
  <% end %>
<% end %>

<% if workspace.active? %>
  <%= render "components/dropdown_menu/item",
      href: workspace_memory_versions_path(workspace, memory),
      method: :post,
      data: { turbo_confirm: "Create a new version from #{memory.version_label}?" } do %>
    <%= icon_for(:copy_plus, class: "size-4") %>
    New Version
  <% end %>

  <%= render "components/dropdown_menu/separator" %>

  <%= render "components/dropdown_menu/item",
      href: edit_workspace_memory_path(workspace, memory) do %>
    <%= icon_for(:edit, class: "size-4") %>
    Edit
  <% end %>

  <% if memory.has_versions? %>
    <%= render "components/dropdown_menu/item",
        href: workspace_memory_version_consolidation_path(workspace, memory, memory),
        method: :post,
        variant: :destructive,
        data: { turbo_confirm: "Delete all other versions? Only #{memory.version_label} will be kept." } do %>
      <%= icon_for(:trash_2, class: "size-4") %>
      Delete Other Versions
    <% end %>
  <% end %>

  <%= render "components/dropdown_menu/separator" %>

  <%= render "components/dropdown_menu/item",
      href: workspace_memory_path(workspace, memory),
      method: :delete,
      variant: :destructive,
      data: { turbo_confirm: "Are you sure you want to delete this memory?" } do %>
    <%= icon_for(:trash_2, class: "size-4") %>
    Delete
  <% end %>
<% end %>
