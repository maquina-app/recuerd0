<%= render "components/card" do %>
  <%= render "components/card_header", class_names: "text-center" do %>
    <h2 class="text-xl font-semibold">Update your password</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your new password below
    </p>
  <% end %>

  <%= render "components/card_content" do %>
    <%= form_with url: password_path(params[:token]), method: :put do |form| %>
      <div class="grid gap-6">
        <div class="grid gap-3">
          <%= form.label :password, "New password", class: "text-sm font-medium" %>
          <%= form.password_field :password,
                              required: true,
                              autofocus: true,
                              autocomplete: "new-password",
                              placeholder: "Enter new password",
                              maxlength: 72,
                              class: "w-full" %>
        </div>

        <div class="grid gap-3">
          <%= form.label :password_confirmation,
                     "Confirm password",
                     class: "text-sm font-medium" %>
          <%= form.password_field :password_confirmation,
                              required: true,
                              autocomplete: "new-password",
                              placeholder: "Repeat new password",
                              maxlength: 72,
                              class: "w-full" %>
        </div>

        <%= form.submit "Update password", class: "btn-default w-full" %>

        <div class="text-center text-sm">
          <%= link_to "Back to sign in",
          new_session_path,
          class: "underline underline-offset-4" %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
