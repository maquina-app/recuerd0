<% content_for :title, "Update password — recuerd0" %>

<%= render "components/card" do %>
  <%= render "components/card/header", css_classes: "text-center" do %>
    <h2 class="text-xl font-display font-medium">Update your password</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your new password below
    </p>
  <% end %>

  <%= render "components/card/content" do %>
    <%= form_with url: password_path(params[:token]), method: :put, data: { component: "form" } do |form| %>
      <div data-form-part="group">
        <%= form.label :password, "New password", data: { component: "label" } %>
        <%= form.password_field :password,
            required: true,
            autofocus: true,
            autocomplete: "new-password",
            placeholder: t("passwords.edit.password_placeholder"),
            maxlength: 72,
            spellcheck: "false",
            data: { component: "input" } %>
      </div>

      <div data-form-part="group">
        <%= form.label :password_confirmation, "Confirm password", data: { component: "label" } %>
        <%= form.password_field :password_confirmation,
            required: true,
            autocomplete: "new-password",
            placeholder: t("passwords.edit.password_confirmation_placeholder"),
            maxlength: 72,
            spellcheck: "false",
            data: { component: "input" } %>
      </div>

      <div data-form-part="actions">
        <%= form.submit "Update password",
            data: { component: "button", variant: "primary" }, class: "w-full" %>
      </div>

      <div class="text-center text-sm">
        <%= link_to "Back to sign in",
            new_session_path,
            class: "underline underline-offset-4" %>
      </div>
    <% end %>
  <% end %>
<% end %>
