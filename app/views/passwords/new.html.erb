<% content_for :title, "Reset password — recuerd0" %>

<%= render "components/card" do %>
  <%= render "components/card/header", css_classes: "text-center" do %>
    <h2 class="text-xl font-display font-medium">Forgot your password?</h2>
    <p class="text-sm text-muted-foreground mt-1">
      Enter your email and we'll send you reset instructions
    </p>
  <% end %>

  <%= render "components/card/content" do %>
    <%= form_with url: passwords_path, data: { component: "form" } do |form| %>
      <div data-form-part="group">
        <%= form.label :email_address, "Email", data: { component: "label" } %>
        <%= form.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            autocapitalize: "none",
            maxlength: 80,
            placeholder: "m@example.com",
            value: params[:email_address],
            data: { component: "input" } %>
      </div>

      <div data-form-part="actions">
        <%= form.submit "Send reset instructions",
            data: { component: "button", variant: "primary" }, class: "w-full" %>
      </div>

      <div class="text-center text-sm">
        Remember your password?
        <%= link_to "Sign in", new_session_path, class: "underline underline-offset-4" %>
      </div>
    <% end %>
  <% end %>
<% end %>
