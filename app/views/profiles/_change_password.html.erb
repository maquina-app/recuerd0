<%# locals: (user:) %>
<%= render "components/card" do %>
  <%= render "components/card/header" do %>
    <%= render "components/card/title", text: t("profiles.change_password.title") %>
    <%= render "components/card/description", text: t("profiles.change_password.description") %>
  <% end %>

  <%= render "components/card/content" do %>
    <%= form_with(url: profile_password_path, method: :patch, data: { component: "form" }) do |form| %>
      <div data-form-part="group">
        <%= form.label :current_password, t("profiles.change_password.current_password_label"), data: { component: "label" } %>
        <%= form.password_field :current_password,
            required: true,
            autocomplete: "current-password",
            data: { component: "input" } %>
      </div>

      <div data-form-part="group">
        <%= form.label :password, t("profiles.change_password.new_password_label"), data: { component: "label" } %>
        <%= form.password_field :password,
            required: true,
            minlength: 8,
            autocomplete: "new-password",
            data: { component: "input" } %>
      </div>

      <div data-form-part="group">
        <%= form.label :password_confirmation, t("profiles.change_password.confirm_password_label"), data: { component: "label" } %>
        <%= form.password_field :password_confirmation,
            required: true,
            minlength: 8,
            autocomplete: "new-password",
            data: { component: "input" } %>
      </div>

      <div data-form-part="actions">
        <%= form.submit t("profiles.change_password.submit"),
            data: { component: "button", variant: "primary" } %>
      </div>
    <% end %>
  <% end %>
<% end %>
