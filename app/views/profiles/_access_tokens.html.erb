<%# locals: (user:, access_tokens:) %>
<%= render "components/card" do %>
  <%= render "components/card/header" do %>
    <%= render "components/card/title", text: t("profiles.access_tokens.title") %>
    <%= render "components/card/description", text: t("profiles.access_tokens.description") %>
  <% end %>

  <%= render "components/card/content" do %>
    <%# New token display (shown once after creation) %>
    <% if flash[:new_token].present? %>
      <%= render "components/alert", variant: :success, icon: :check_circle, css_classes: "mb-6" do %>
        <strong><%= t("profiles.access_tokens.token_created") %></strong>
        <div class="mt-2" data-controller="clipboard">
          <div class="flex items-center gap-2">
            <input type="text"
                   value="<%= flash[:new_token] %>"
                   readonly
                   onclick="this.select()"
                   data-component="input"
                   data-clipboard-target="source"
                   class="font-mono text-xs flex-1" />
            <button type="button"
                    data-action="clipboard#copy"
                    data-component="button"
                    data-variant="outline"
                    data-size="icon"
                    class="shrink-0"
                    title="<%= t("profiles.access_tokens.copy_tooltip") %>">
              <span data-clipboard-target="copyIcon"><%= icon_for(:copy, class: "size-4") %></span>
              <span data-clipboard-target="checkIcon" class="hidden"><%= icon_for(:check, class: "size-4") %></span>
            </button>
          </div>
          <p class="text-xs text-muted-foreground mt-1"><%= t("profiles.access_tokens.token_warning") %></p>
        </div>
      <% end %>
    <% end %>

    <%# Token list %>
    <% if access_tokens.any? %>
      <%= render "components/table" do %>
        <%= render "components/table/header" do %>
          <%= render "components/table/row" do %>
            <%= render "components/table/head" do %><%= t("profiles.access_tokens.col_description") %><% end %>
            <%= render "components/table/head" do %><%= t("profiles.access_tokens.col_permission") %><% end %>
            <%= render "components/table/head", css_classes: "hidden sm:table-cell" do %><%= t("profiles.access_tokens.col_created") %><% end %>
            <%= render "components/table/head", css_classes: "hidden sm:table-cell" do %><%= t("profiles.access_tokens.col_last_used") %><% end %>
            <%= render "components/table/head", css_classes: "w-12" do %><% end %>
          <% end %>
        <% end %>

        <%= render "components/table/body" do %>
          <% access_tokens.each do |token| %>
            <%= render "components/table/row" do %>
              <%= render "components/table/cell" do %>
                <% if token.description.present? %>
                  <span class="text-sm font-medium"><%= token.description %></span>
                <% else %>
                  <span class="text-sm text-muted-foreground italic"><%= t("profiles.access_tokens.untitled") %></span>
                <% end %>
              <% end %>
              <%= render "components/table/cell" do %>
                <% if token.full_access? %>
                  <%= render "components/badge", variant: :default do %><%= t("profiles.access_tokens.full_access") %><% end %>
                <% else %>
                  <%= render "components/badge", variant: :secondary do %><%= t("profiles.access_tokens.read_only") %><% end %>
                <% end %>
              <% end %>
              <%= render "components/table/cell", css_classes: "hidden sm:table-cell" do %>
                <span class="text-sm text-muted-foreground"><%= time_ago_in_words(token.created_at) %> ago</span>
              <% end %>
              <%= render "components/table/cell", css_classes: "hidden sm:table-cell" do %>
                <span class="text-sm text-muted-foreground">
                  <%= token.last_used_at ? "#{time_ago_in_words(token.last_used_at)} ago" : t("profiles.access_tokens.never_used") %>
                </span>
              <% end %>
              <%= render "components/table/cell" do %>
                <%= button_to profile_access_token_path(token),
                    method: :delete,
                    data: {
                      component: "button",
                      variant: "ghost",
                      size: "icon-sm",
                      turbo_confirm: t("profiles.access_tokens.delete_confirm")
                    },
                    class: "text-destructive hover:text-destructive" do %>
                  <%= icon_for(:trash_2, class: "size-4") %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <%= render "components/empty", variant: :outline do %>
        <%= render "components/empty/media" do %>
          <%= icon_for(:key, class: "w-12 h-12 text-muted-foreground") %>
        <% end %>
        <%= render "components/empty/title", text: t("profiles.access_tokens.empty_title") %>
        <%= render "components/empty/description", text: t("profiles.access_tokens.empty_description") %>
      <% end %>
    <% end %>

    <%# Create token form — custom layout, no data-component="form" %>
    <div class="mt-6 pt-6 border-t border-border">
      <h4 class="text-sm font-medium mb-4"><%= t("profiles.access_tokens.create_title") %></h4>
      <%= form_with(url: profile_access_tokens_path, method: :post) do |form| %>
        <div class="flex flex-col sm:flex-row items-end gap-3">
          <div data-form-part="group" class="flex-1 w-full">
            <%= form.label "access_token[description]", t("profiles.access_tokens.description_label"), data: { component: "label" } %>
            <%= form.text_field "access_token[description]",
                placeholder: t("profiles.access_tokens.description_placeholder"),
                maxlength: 255,
                autocomplete: "off",
                data: { component: "input" } %>
          </div>

          <div data-form-part="group" class="w-full sm:w-40 shrink-0">
            <%= form.label "access_token[permission]", t("profiles.access_tokens.permission_label"), data: { component: "label" } %>
            <%= form.select "access_token[permission]",
                options_for_select([
                  [t("profiles.access_tokens.read_only"), "read_only"],
                  [t("profiles.access_tokens.full_access"), "full_access"]
                ], "read_only"),
                {},
                data: { component: "input" } %>
          </div>

          <%= form.submit t("profiles.access_tokens.create_submit"),
              data: { component: "button", variant: "outline" },
              class: "w-full sm:w-auto shrink-0" %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
