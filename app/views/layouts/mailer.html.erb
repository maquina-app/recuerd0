<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #1a1a1a;
        -webkit-text-size-adjust: 100%;
      }
      .wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      .card {
        background-color: #ffffff;
        border-radius: 8px;
        border: 1px solid #e5e5e5;
        overflow: hidden;
      }
      .header {
        padding: 24px 32px;
        border-bottom: 1px solid #e5e5e5;
      }
      .brand {
        text-decoration: none;
      }
      .brand img {
        height: 32px;
        width: auto;
      }
      .content {
        padding: 32px;
      }
      .content p {
        margin: 0 0 16px;
      }
      .content p:last-child {
        margin-bottom: 0;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background-color: #009D39;
        color: #ffffff !important;
        text-decoration: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        line-height: 1;
      }
      .footer {
        padding: 24px 32px;
        text-align: center;
        font-size: 13px;
        color: #737373;
      }
      .footer a {
        color: #009D39;
        text-decoration: none;
      }
      .muted {
        color: #737373;
        font-size: 14px;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="card">
        <div class="header">
          <a href="<%= root_url %>" class="brand"><%= image_tag(attachments["recuerdo-email.png"].url, alt: "recuerd0", style: "height:32px;width:auto;") %></a>
        </div>

        <div class="content">
          <%= yield %>
        </div>
      </div>

      <div class="footer">
        <p>recuerd0 — LLM context management</p>
        <p style="margin-top: 12px; font-size: 12px;">&copy; 2026 recuerd0 - Mario Alberto Chávez</p>
        <p style="margin-top: 8px; font-size: 12px;">
          Designed &amp; built by
          <a href="https://maquina.app" style="color: #50B1FD; text-decoration: none;"><%= image_tag(attachments["maquina-email.png"].url, alt: "Maquina", style: "height:16px;width:auto;vertical-align:middle;margin-left:4px;") %></a>
        </p>
      </div>
    </div>
  </body>
</html>
