<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recuerd0 - Sign In" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div
      class="
        min-h-screen bg-muted flex flex-col items-center justify-center gap-6 p-6
        md:p-10
      "
    >
      <div class="w-full max-w-sm space-y-6">
        <%= link_to root_path, class: "flex items-center gap-2 self-center font-medium mx-auto w-fit" do %>
          <div
            class="
              bg-primary text-primary-foreground flex w-6 h-6 items-center justify-center
              rounded-md
            "
          >
            <%= icon_for :gallery_vertical_end, class: "w-4 h-4" %>
          </div>
          <span class="font-display text-xl font-medium">Recuerd0</span>
        <% end %>

        <% if flash.any? %>
          <div class="space-y-4">
            <% flash.each do |type, message| %>
              <% variant =
                case type.to_s
                when "notice", "success"
                  "success"
                when "alert", "error"
                  "destructive"
                else
                  "default"
                end %>

              <div
                data-controller="alert"
                data-alert-dismiss-after-value="5000"
                data-alert-remove-after-value="300"
              >
                <%= render "components/alert", variant: variant.to_sym, css_classes: "text-sm" do %>
                  <div class="flex items-start gap-3">
                    <% if variant == "success" %>
                      <%= icon_for :check_circle,
                      class: "w-4 h-4 flex-shrink-0 text-emerald-600 dark:text-emerald-400" %>
                    <% elsif variant == "destructive" %>
                      <%= icon_for :x_circle, class: "w-4 h-4 flex-shrink-0" %>
                    <% else %>
                      <%= icon_for :info, class: "w-4 h-4 flex-shrink-0" %>
                    <% end %>
                    <div class="flex-1"><%= message %></div>
                    <button
                      type="button"
                      class="
                        flex-shrink-0 ml-4 text-current opacity-70 hover:opacity-100 transition-opacity
                      "
                      data-action="click->alert#dismiss"
                      aria-label="Dismiss"
                    >
                      <%= icon_for :x, class: "w-3 h-3" %>
                    </button>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </div>
  </body>
</html>
