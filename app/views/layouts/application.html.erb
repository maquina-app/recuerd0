<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recuerd0" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# Toast notifications container %>
    <div class="toast-container" aria-live="polite" aria-atomic="true">
      <% if flash.any? %>
        <% flash.each do |type, message| %>
          <% variant =
            case type.to_s
            when "notice", "success"
              "success"
            when "alert", "error"
              "destructive"
            else
              "default"
            end %>

          <div
            data-controller="alert"
            data-alert-dismiss-after-value="5000"
            data-alert-remove-after-value="300"
          >
            <%= render "components/alert",
                variant: variant,
                class_names: "flex items-start gap-3 max-w-sm" do %>
              <% if variant == "success" %>
                <%= lucide_icon(
                  :check_circle,
                  size: "w-5 h-5 flex-shrink-0",
                  class: "text-emerald-600 dark:text-emerald-400",
                ) %>
              <% elsif variant == "destructive" %>
                <%= lucide_icon(:x_circle, size: "w-5 h-5 flex-shrink-0") %>
              <% else %>
                <%= lucide_icon(:info, size: "w-5 h-5 flex-shrink-0") %>
              <% end %>
              <div class="flex-1 text-sm">
                <%= message %>
              </div>
              <button
                type="button"
                class="
                  flex-shrink-0 ml-4 text-current opacity-70 hover:opacity-100 transition-opacity
                "
                data-action="click->alert#dismiss"
                aria-label="Dismiss"
              >
                <%= lucide_icon(:x, size: "w-4 h-4") %>
              </button>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="flex h-screen overflow-hidden">
      <%= render "application/sidebar", sidebar_open: @sidebar_open %>
    </div>
  </body>
</html>
